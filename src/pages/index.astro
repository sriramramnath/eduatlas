---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SubjectCard from '../components/SubjectCard.astro';
---

<Layout title="Home">
  <div class="page-wrapper patrick-hand">
    <Header />
    
    <main class="main-content">
      <section class="hero-section">
        <div class="container hero-container">
          <div class="hero-content animate-fade-in">
            <div class="hero-badge-wrapper">
              <span class="hero-badge tag glass">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sparkle"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707.707"/></svg>
                <span class="patrick-hand">Free IGCSE Resources</span>
        <div class="container hero-container centered">
          
          <div class="hero-visual animate-float large-mode">
            <div class="large-icon-wrapper glass">
              <img src="/Lightmodeicon.png" alt="EduAtlas Logo" class="hero-large-icon" />
            </div>
          </div>
        </div>
      </section>

      <section class="subjects-section" id="subjects">
        <div class="container">
          <div class="section-header animate-fade-in">
            <h2 class="section-title wiggly-heading patrick-hand">Master Your Subjects</h2>
            <p class="section-subtitle patrick-hand">Deep dive into our comprehensive curricula curated for excellence</p>
          </div>
          
          <div class="subjects-grid">
            <SubjectCard 
              title="Biology"
              description="Explore the living world from microscopic cells to complex ecosystems. Master human physiology, genetics, and more."
              href="/subjects/biology"
              color="#10b981"
              icon="biology"
              chapterCount={10}
            />
            <SubjectCard 
              title="Chemistry"
              description="Understand the building blocks of matter. Coverage includes atomic structure, bonding, and organic chemistry."
              href="/subjects/chemistry"
              color="#3b82f6"
              icon="chemistry"
              chapterCount={10}
            />
            <SubjectCard 
              title="Physics"
              description="Learn the fundamental laws of the universe. From forces and energy to waves and electromagnetism."
              href="/subjects/physics"
              color="#f59e0b"
              icon="physics"
              chapterCount={10}
            />
            <SubjectCard 
              title="ICT"
              description="Navigate the digital world. Master computing fundamentals, data communication, and software applications."
              href="/subjects/ict"
              color="#8b5cf6"
              icon="ict"
              chapterCount={8}
            />
            <SubjectCard 
              title="Mathematics"
              description="Strengthen your mathematical foundations. Comprehensive coverage of numbers, algebra, and geometry."
              href="/subjects/math"
              color="#ec4899"
              icon="math"
              chapterCount={12}
            />
          </div>
        </div>
      </section>

      <section class="features-section">
        <div class="container">
          <div class="section-header">
            <h2 class="section-title wiggly-heading patrick-hand">Why Choose EduAtlas?</h2>
            <p class="section-subtitle patrick-hand">A playful yet professional learning experience designed for high-achievers</p>
          </div>
          
          <div class="features-grid">
            <div class="feature-card card">
              <div class="feature-icon-wrapper">
                <img src="/Lightmodeicon.png" alt="" class="feat-img" />
              </div>
              <h3 class="feature-card-title patrick-hand">Curated Content</h3>
              <p class="feature-card-desc patrick-hand">Every note is meticulously reviewed to align with the latest Pearson Edexcel specifications.</p>
            </div>
            
            <div class="feature-card card">
              <div class="feature-icon-wrapper">
                 <img src="/Lightmodeicon.png" alt="" class="feat-img" />
              </div>
              <h3 class="feature-card-title patrick-hand">Interactive Quizzes</h3>
              <p class="feature-card-desc patrick-hand">Instant feedback loops with detailed explanations to reinforce your understanding.</p>
            </div>
            
            <div class="feature-card card">
              <div class="feature-icon-wrapper">
                <img src="/Lightmodeicon.png" alt="" class="feat-img" />
              </div>
              <h3 class="feature-card-title patrick-hand">Practice Matters</h3>
              <p class="feature-card-desc patrick-hand">Extensive question banks with worked solutions to prepare you for the real exam environment.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="cta-section">
        <div class="container animate-fade-in">
          <div class="cta-banner card glass">
            <div class="cta-content">
              <h2 class="cta-headline patrick-hand">Ready to boost your grades?</h2>
              <p class="cta-text patrick-hand">Join thousands of students and start your journey to academic excellence today.</p>
              <div class="cta-actions">
                <a href="/subjects" class="btn lg patrick-hand">Get Started Now</a>
              </div>
            </div>
            <div class="cta-visual">
               <div class="badge-large patrick-hand">100% FREE</div>
            </div>
          </div>
        </div>
      </section>
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    padding: 6rem 0 8rem;
    overflow: hidden;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-container { grid-template-columns: 1.2fr 0.8fr; }
  }

  .patrick-hand {
    font-family: 'Patrick Hand', cursive !important;
  }

  .hero-badge-wrapper {
    margin-bottom: 2rem;
  }

  .hero-badge {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-weight: 700;
  }

  .sparkle { color: var(--app-accent); margin-right: 0.5rem; }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    margin: 0 0 1.5rem 0;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--app-text-muted);
    max-width: 600px;
    margin: 0 0 3rem 0;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .btn.lg {
    padding: 0.85rem 2.25rem;
    font-size: 1.4rem;
  }
  
  .btn-icon {
    flex-shrink: 0;
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    display: none;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-visual { display: flex; }
  }

  .large-icon-wrapper {
    width: 380px;
    height: 380px;
    border-radius: 4rem;
    border: 3px solid var(--app-border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    box-shadow: 0 40px 80px rgba(0,0,0,0.1);
    transform: rotate(-5deg);
    transition: all 0.5s ease;
  }

  .large-icon-wrapper:hover {
    transform: rotate(0deg) scale(1.05);
  }

  .hero-large-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15));
  }


  /* Subjects Section */
  .subjects-section { padding: 6rem 0; }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-title { font-size: 2.75rem; margin-bottom: 1rem; }
  .section-subtitle { color: var(--app-text-muted); font-size: 1.2rem; }

  .subjects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* Features Section */
  .features-section {
    padding: 6rem 0;
    background: var(--app-surface-muted);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    padding: 2.5rem;
    text-align: center;
  }

  .feature-icon-wrapper {
    width: 72px;
    height: 72px;
    border-radius: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    overflow: hidden;
    border: 3px solid var(--app-border);
    background: white;
    padding: 8px;
  }

  .feat-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .feature-card-title { font-size: 1.75rem; margin-bottom: 0.75rem; }
  .feature-card-desc { color: var(--app-text-muted); font-size: 1.05rem; }

  /* CTA Section */
  .cta-section { padding: 6rem 0 10rem; }

  .cta-banner {
    border-radius: 2.5rem;
    padding: 4rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  @media (min-width: 1024px) {
    .cta-banner {
      grid-template-columns: 1.2fr 0.8fr;
      text-align: left;
    }
  }

  .cta-headline { font-size: 3rem; margin-bottom: 1rem; }
  .cta-text { font-size: 1.25rem; color: var(--app-text-muted); margin-bottom: 2.5rem; }

  .cta-visual { display: flex; justify-content: center; align-items: center; }
  .badge-large {
    font-size: 4rem;
    font-weight: 800;
    color: var(--app-accent);
    transform: rotate(-10deg);
  }
</style>
