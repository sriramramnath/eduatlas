---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { getSubjects, getChapter } from '../../../../utils/subjects';
import { contentSubjectConfigs } from '../../../../utils/contentSubjects';

export function getStaticPaths() {
  const subjects = getSubjects();
  const paths: Array<{params: {subjectId: string; chapterId: string}}> = [];
  
  for (const subjectId of Object.keys(subjects)) {
    const subject = subjects[subjectId];
    for (const chapter of subject.chapters) {
      paths.push({
        params: { subjectId, chapterId: chapter.id }
      });
    }
  }
  
  return paths;
}

const { subjectId, chapterId } = Astro.params;
const subjects = getSubjects();
const subject = subjects[subjectId!];
const chapter = getChapter(subjectId!, chapterId!);

if (!subject || !chapter) {
  return Astro.redirect('/subjects');
}

const bannerMap: Record<string, string> = {
  'biology': '/banners/biology.png',
  'chemistry': '/banners/chemistry.png',
  'physics': '/banners/physics.png',
  'maths': '/banners/math.png',
  'ict': '/banners/compsci.png',
};

const bannerSrc = bannerMap[subjectId!] || '';

// Import all chapter content files
const noteModules = import.meta.glob('/src/subjects/*/chapter-*/note.md', { eager: true });
const synopsisModules = import.meta.glob('/src/subjects/*/chapter-*/synopsis.md', { eager: true });
const quizModules = import.meta.glob('/src/subjects/*/chapter-*/quiz.md', { eager: true });
const practiceModules = import.meta.glob('/src/subjects/*/chapter-*/practice.md', { eager: true });
const biologyNoteModules = import.meta.glob('/src/newcontent/Biology/Biology_Chapter*_Notes.md', { eager: true });
const biologySynopsisModules = import.meta.glob('/src/newcontent/Biology/Biology_Chapter*_Synopsis.md', { eager: true });
const biologyQuizModules = import.meta.glob('/src/newcontent/Biology/Biology_Chapter*_Quiz.md', { eager: true });
const chemistryNoteModules = import.meta.glob('/src/newcontent/chemistry/Chemistry_Ch*_Notes.md', { eager: true });
const chemistrySynopsisModules = import.meta.glob('/src/newcontent/chemistry/Chemistry_Ch*_Synopsis.md', { eager: true });
const chemistryQuizModules = import.meta.glob('/src/newcontent/chemistry/Chemistry_Ch*_Quiz.md', { eager: true });
const physicsNoteModules = import.meta.glob('/src/newcontent/physics/Physics_*_Notes.md', { eager: true });
const physicsSynopsisModules = import.meta.glob('/src/newcontent/physics/Physics_*_Synopsis.md', { eager: true });
const physicsQuizModules = import.meta.glob('/src/newcontent/physics/Physics_*_Quiz.md', { eager: true });
const ictNoteModules = import.meta.glob('/src/newcontent/ICT/ICT_Chapter*_Notes.md', { eager: true });
const ictSynopsisModules = import.meta.glob('/src/newcontent/ICT/ICT_Chapter*_Synopsis.md', { eager: true });
const ictQuizModules = import.meta.glob('/src/newcontent/ICT/ICT_Chapter*_Quiz.md', { eager: true });
const mathsNoteModules = import.meta.glob('/src/newcontent/maths/Mathematics_Chapter*_Notes.md', { eager: true });
const mathsSynopsisModules = import.meta.glob('/src/newcontent/maths/Mathematics_Chapter*_Synopsis.md', { eager: true });
const mathsQuizModules = import.meta.glob('/src/newcontent/maths/Mathematics_Chapter*_Quiz.md', { eager: true });

// Find the content for this chapter
const isBiology = subjectId === 'biology';
const isChemistry = subjectId === 'chemistry';
const isPhysics = subjectId === 'physics';
const isIct = subjectId === 'ict';
const isMaths = subjectId === 'maths';

const contentSubjectConfig = isBiology
  ? contentSubjectConfigs.biology
  : isChemistry
    ? contentSubjectConfigs.chemistry
    : isPhysics
      ? contentSubjectConfigs.physics
      : isIct
        ? contentSubjectConfigs.ict
        : isMaths
          ? contentSubjectConfigs.maths
          : null;
const chapterPathParam = isMaths ? chapter.id.replace('chapter-', '') : chapter.number;
const notePath = contentSubjectConfig
  ? contentSubjectConfig.notePath(chapterPathParam)
  : `/src/subjects/${subjectId}/${chapterId}/note.md`;
const synopsisPath = contentSubjectConfig
  ? contentSubjectConfig.synopsisPath(chapterPathParam)
  : `/src/subjects/${subjectId}/${chapterId}/synopsis.md`;
const quizPath = contentSubjectConfig
  ? contentSubjectConfig.quizPath(chapterPathParam)
  : `/src/subjects/${subjectId}/${chapterId}/quiz.md`;
const practicePath = `/src/subjects/${subjectId}/${chapterId}/practice.md`;

const contentNoteModules = isBiology
  ? biologyNoteModules
  : isChemistry
    ? chemistryNoteModules
    : isPhysics
      ? physicsNoteModules
      : isIct
        ? ictNoteModules
        : isMaths
          ? mathsNoteModules
          : noteModules;
const contentSynopsisModules = isBiology
  ? biologySynopsisModules
  : isChemistry
    ? chemistrySynopsisModules
    : isPhysics
      ? physicsSynopsisModules
      : isIct
        ? ictSynopsisModules
        : isMaths
          ? mathsSynopsisModules
          : synopsisModules;
const contentQuizModules = isBiology
  ? biologyQuizModules
  : isChemistry
    ? chemistryQuizModules
    : isPhysics
      ? physicsQuizModules
      : isIct
        ? ictQuizModules
        : isMaths
          ? mathsQuizModules
          : quizModules;

const noteModule = contentNoteModules[notePath] as any;
const synopsisModule = contentSynopsisModules[synopsisPath] as any;
const quizModule = contentQuizModules[quizPath] as any;
const practiceModule = practiceModules[practicePath] as any;
const biologyPracticeLinks = [
  {
    label: 'Mock Paper 1',
    href: '/biology/practice/IGCSE_Biology_Mock1_Paper1.pdf',
    description: 'First full mock paper for chapter practice and exam timing.',
    meta: 'PDF',
  },
  {
    label: 'Mock Paper 2',
    href: '/biology/practice/IGCSE_Biology_Mock1_Paper2.pdf',
    description: 'Second mock paper using the same format for repeated revision.',
    meta: 'PDF',
  },
  {
    label: 'Mark Scheme',
    href: '/biology/practice/IGCSE_Biology_Mock1_MarkSchemes.pdf',
    description: 'Official answers and mark allocations for both mock papers.',
    meta: 'PDF',
  },
];

const tabIcons: Record<string, string> = {
  notes: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>',
  synopsis: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  quiz: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>',
  practice: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>',
};
---

<Layout title={`${chapter.title} - ${subject.title}`}>
  <div class="page-wrapper patrick-hand">
    <Header />
    
    <main class="main-content">
      <section class="chapter-hero">
        <img src={bannerSrc} alt="" class="hero-bg-image" />
        <div class="hero-overlay"></div>
        <div class="container animate-fade-in">
          <nav class="breadcrumb">
            <a href="/" class="breadcrumb-link">Home</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            <a href="/subjects" class="breadcrumb-link">Subjects</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            <a href={`/subjects/${subjectId}`} class="breadcrumb-link">{subject.title}</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="breadcrumb-current">Chapter {chapter.number}</span>
          </nav>
          
          <div class="chapter-header">
            <div class="chapter-tag-wrap">
              <span class="chapter-tag" style={`background: ${subject.color}`}>Chapter {chapter.number}</span>
            </div>
            <h1 class="hero-title wiggly-heading">{chapter.title}</h1>
            <p class="hero-subtitle">{chapter.synopsis}</p>
            <div class="chapter-meta">
              <span class="meta-item glass">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {chapter.estimatedTime}
              </span>
              <span class="meta-item glass">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
                {chapter.topics.length} Topics
              </span>
            </div>
          </div>
        </div>
      </section>

      <section class="chapter-content-section">
        <div class="container">
          <div class="tabs-nav glass">
            <div class="tabs-list" style={`--tab-accent: ${subject.color}`} id="tabs-nav">
              <button class="tab-item active" data-tab="notes">
                 <div class="tab-icon" set:html={tabIcons.notes} />
                 <span>Notes</span>
              </button>
              <button class="tab-item" data-tab="synopsis">
                 <div class="tab-icon" set:html={tabIcons.synopsis} />
                 <span>Synopsis</span>
              </button>
              <button class="tab-item" data-tab="quiz">
                 <div class="tab-icon" set:html={tabIcons.quiz} />
                 <span>Quiz</span>
              </button>
              <button class="tab-item" data-tab="practice">
                 <div class="tab-icon" set:html={tabIcons.practice} />
                 <span>Practice</span>
              </button>
            </div>
          </div>

          <div class="tab-panel animate-fade-in">
            <div class="tab-content" id="tab-notes">
              <div class="notes-panel">
                <div class="panel-card card">
                  <div class="card-header-accent" style={`background: ${subject.color}`}>
                    <h2 class="panel-card-title">Study Material</h2>
                  </div>
                  <div class="card-body">
                    {noteModule ? (
                      <div class="markdown-content">
                        <noteModule.Content />
                      </div>
                    ) : (
                      <div class="no-content">
                         <p>Detailed notes for this chapter are coming soon.</p>
                         <h3 class="panel-subheading wiggly-heading">Topics Covered</h3>
                         <div class="topics-grid">
                            {chapter.topics.map((topic, index) => (
                              <div class="topic-item card glass">
                                 <span class="topic-num">{index + 1}</span>
                                 <span class="topic-label">{topic}</span>
                              </div>
                            ))}
                         </div>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div class="tab-content hidden" id="tab-synopsis">
              <div class="notes-panel animate-fade-in">
                <div class="panel-card card">
                  <div class="card-header-accent" style={`background: ${subject.color}`}>
                    <h2 class="panel-card-title">Synopsis</h2>
                  </div>
                  <div class="card-body">
                    {synopsisModule ? (
                      <div class="markdown-content">
                        <synopsisModule.Content />
                      </div>
                    ) : (
                      <div class="no-content">
                         <p>Synopsis coming soon.</p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div class="tab-content hidden" id="tab-quiz">
              <div class="notes-panel animate-fade-in">
                <div class="panel-card card">
                  <div class="card-header-accent" style={`background: ${subject.color}`}>
                    <h2 class="panel-card-title">Quiz</h2>
                  </div>
                  <div class="card-body">
                    {quizModule ? (
                      <div class="markdown-content">
                        <quizModule.Content />
                      </div>
                    ) : (
                      <div class="no-content">
                         <p>Quiz coming soon.</p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div class="tab-content hidden" id="tab-practice">
              <div class="notes-panel animate-fade-in">
                <div class="panel-card card">
                  <div class="card-header-accent" style={`background: ${subject.color}`}>
                    <h2 class="panel-card-title">Practice Questions</h2>
                  </div>
                  <div class="card-body">
                    {isBiology ? (
                      <div class="practice-links">
                        {biologyPracticeLinks.map((resource) => (
                          <a
                            href={resource.href}
                            target="_blank"
                            rel="noreferrer"
                            class="practice-link-card card glass"
                          >
                            <div class="practice-link-main">
                              <div class="practice-link-icon" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15h6"/><path d="M9 18h6"/><path d="M10 12h1"/></svg>
                              </div>
                              <div class="practice-link-copy">
                                <span class="practice-link-label">{resource.label}</span>
                                <span class="practice-link-description">{resource.description}</span>
                              </div>
                            </div>
                            <div class="practice-link-side">
                              <span class="practice-link-meta">{resource.meta}</span>
                              <span class="practice-link-action">Open</span>
                            </div>
                          </a>
                        ))}
                      </div>
                    ) : practiceModule ? (
                      <div class="markdown-content">
                        <practiceModule.Content />
                      </div>
                    ) : (
                      <div class="no-content">
                         <p>Practice questions coming soon.</p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    
    <Footer />
  </div>
</Layout>

<script>
  console.log('[Quiz] Script tag loaded');
  // Tab switching logic
  function initTabs() {
    const tabButtons = document.querySelectorAll('.tab-item[data-tab]');
    const tabContents = document.querySelectorAll('.tab-content');
    
    // Get initial tab from URL or default to notes
    const urlParams = new URLSearchParams(window.location.search);
    let activeTab = urlParams.get('tab') || 'notes';
    
    function setActiveTab(tabId: string) {
      // Update buttons
      tabButtons.forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-tab') === tabId);
      });
      
      // Update content
      tabContents.forEach(content => {
        content.classList.toggle('hidden', content.id !== `tab-${tabId}`);
      });
      
      // Update URL
      const url = new URL(window.location.href);
      if (tabId === 'notes') {
        url.searchParams.delete('tab');
      } else {
        url.searchParams.set('tab', tabId);
      }
      window.history.replaceState({}, '', url.toString());
    }
    
    // Initialize
    setActiveTab(activeTab);
    
    // Add click handlers
    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        if (tabId) {
          setActiveTab(tabId);
        }
      });
    });
  }

  function stripWrappedQuotes(value: string) {
    return value.replace(/^["']|["']$/g, '').trim();
  }

  function getLeadingLabel(text: string) {
    const match = text.match(/^([A-Z])\)\s+/);
    return match ? match[1] : '';
  }

  function stripLeadingLabel(text: string) {
    return text.replace(/^[A-Z]\)\s+/, '').trim();
  }

  function normalizeAnswerValue(value: string) {
    return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
  }

  function parseAnswerLine(text: string) {
    return text
      .replace(/^[\s\*]*\*\*[\s\*]*answer:\*\*[\s\*]*/i, '')
      .replace(/^[\s\*]*correct answer:\*\*[\s\*]*/i, '')
      .replace(/^[\s\*]*answer:\s*/i, '')
      .replace(/[\s\*]+$/, '')
      .trim();
  }

  function parseExplanationLine(text: string) {
    return text
      .replace(/^[\s\*]*\*\*(explanation|correction):\*[\s\*]*/i, '$1:')
      .replace(/^[\s\*]*(explanation|correction):\s*/i, '')
      .replace(/[\s\*]+$/, '')
      .trim();
  }

  function stripHtmlTags(value: string) {
    const temp = document.createElement('div');
    temp.innerHTML = value;
    return temp.textContent?.trim() || '';
  }

  function getParagraphLines(node: Element, keepHtml: boolean = false) {
    if (keepHtml) {
      return node.innerHTML
        .split(/<br\s*\/?>/i)
        .map((line) => line.replace(/\u00a0/g, ' ').trim())
        .filter(Boolean);
    }
    return node.innerHTML
      .split(/<br\s*\/?>/i)
      .map((line) => stripHtmlTags(line))
      .map((line) => line.replace(/\u00a0/g, ' ').trim())
      .filter(Boolean);
  }

  function parseQuizBlock(nodes: Element[]) {
    const heading = nodes[0];
    const headingText = heading.textContent?.trim() || '';
    console.log('[Quiz] parseQuizBlock called, heading:', headingText);
    const contentNodes = nodes.slice(1);
    
    // Check for Short Answer Questions (SAQ)
    const isSAQ = contentNodes.some((node) => 
      node.tagName === 'P' && /^[\s\*]*(mark scheme:|mark scheme)/i.test(node.textContent?.replace(/\*/g, '') || '')
    );

    if (isSAQ) {
      const markSchemeIndex = contentNodes.findIndex((node) => 
        node.tagName === 'P' && /^[\s\*]*(mark scheme:|mark scheme)/i.test(node.textContent?.replace(/\*/g, '') || '')
      );

      const promptHtml = contentNodes.slice(0, markSchemeIndex).map(n => n.outerHTML).join('');
      const explanationHtml = contentNodes.slice(markSchemeIndex + 1).map(n => n.outerHTML).join('');

      return {
        isSAQ: true,
        heading: headingText,
        prompt: promptHtml,
        options: [],
        correctValue: '',
        answerLabel: '',
        explanation: explanationHtml,
      };
    }

    const paragraphs = contentNodes.filter((node) => node.tagName === 'P');
    const textParagraphs = paragraphs.flatMap((node) => getParagraphLines(node, false));
    const htmlParagraphs = paragraphs.flatMap((node) => getParagraphLines(node, true));
    console.log('[Quiz] textParagraphs:', textParagraphs.slice(0, 5));

    // For broken format where answer comes before options, we need to get ALL text from ALL paragraphs in this block
    const allBlockText = paragraphs.flatMap((node) => {
      const html = node.innerHTML;
      // Get plain text
      const temp = document.createElement('div');
      temp.innerHTML = html;
      return temp.textContent || '';
    }).join(' | ');

    // Find answer line - look in ALL text paragraphs
    const answerIndex = textParagraphs.findIndex((text) => /^[\s\*]*(answer:|correct answer:)/i.test(text.replace(/\*/g, '')) && !/(explanation|correction):/i.test(text));
    console.log('[Quiz] answerLine:', answerIndex !== -1 ? textParagraphs[answerIndex] : 'NOT FOUND');
    if (answerIndex === -1) {
      console.log('[Quiz] Returning null - no answer line found');
      return null;
    }
    const answerLine = textParagraphs[answerIndex];

    const explanationIndex = textParagraphs.findIndex((text) => /^[\s\*]*(explanation|correction):/i.test(text.replace(/\*/g, '')));
    
    // Get ALL options from the entire block (handles broken format where options come after answer)
    const allOptionParagraphs = textParagraphs.filter((text) => /^[A-Z]\)\s+/.test(text));
    const allOptionHtmlParagraphs = htmlParagraphs.filter((text) => /^[A-Z]\)\s+/.test(stripHtmlTags(text)));
    
    // For prompt, look in text that's not options or answer/explanation
    const promptIndex = textParagraphs.findIndex(
      (text) =>
        !/^[A-Z]\)\s+/.test(text) &&
        !/(answer:|correct answer:)/i.test(text) &&
        !/(explanation|correction):/i.test(text) &&
        text.trim().length > 5,
    );
    
    const optionParagraphs = allOptionParagraphs;
    const optionHtmlParagraphs = allOptionHtmlParagraphs;

    const isTrueFalse = /statement/i.test(headingText);
    const answerValue = parseAnswerLine(answerLine);

    let options = optionHtmlParagraphs.map((html) => ({
      value: getLeadingLabel(stripHtmlTags(html)),
      label: stripLeadingLabel(html),
    }));

    let correctValue = '';
    if (isTrueFalse) {
      options = [
        { value: 'true', label: 'True' },
        { value: 'false', label: 'False' },
      ];
      correctValue = normalizeAnswerValue(answerValue);
    } else {
      const answerMatch = answerValue.match(/[A-Z]/i);
      correctValue = answerMatch ? answerMatch[0].toUpperCase() : '';
    }

    // If options not found but answer is valid, still return (may be broken format)
    // For MCQ we need options, for True/False we don't
    if (!options.length && !isTrueFalse && !correctValue) {
      return null;
    }

    const promptHtml = promptIndex !== -1 ? htmlParagraphs[promptIndex] : headingText;
    const explanationHtml = explanationIndex !== -1 ? parseExplanationLine(htmlParagraphs[explanationIndex]) : 'Review the marked answer and chapter notes for the reasoning.';
    const answerHtml = answerIndex !== -1 ? parseAnswerLine(htmlParagraphs[answerIndex]) : answerValue;

    return {
      heading: headingText,
      prompt: promptHtml,
      options,
      correctValue,
      answerLabel: answerHtml,
      explanation: explanationHtml,
    };
  }

  function buildQuizCard(question: {
    isSAQ?: boolean;
    heading: string;
    prompt: string;
    options: Array<{ value: string; label: string }>;
    correctValue: string;
    answerLabel: string;
    explanation: string;
  }) {
    const card = document.createElement('article');
    card.className = 'quiz-card card';
    card.dataset.correct = question.correctValue;
    const numberMatch = question.heading.match(/(\d+)/);
    const questionNumber = numberMatch ? numberMatch[1] : '1';
    const markMatch = question.heading.match(/\((\d+)\s*mark/i);
    const marks = markMatch ? `${markMatch[1]} mark${markMatch[1] === '1' ? '' : 's'}` : '1 mark';

    if (question.isSAQ) {
      card.innerHTML = `
        <div class="quiz-card-shell saq-card-shell">
          <div class="quiz-card-top">
            <div class="quiz-number-badge">${questionNumber}</div>
            <div class="quiz-mark-badge">${marks}</div>
          </div>
          <div class="quiz-card-divider"></div>
          <div class="quiz-card-body">
            <div class="quiz-card-question saq-prompt">${question.prompt}</div>
          </div>
          <div class="quiz-card-footer">
            <div class="quiz-feedback hidden" aria-live="polite">
              <div class="quiz-feedback-main">
                <p class="quiz-feedback-answer"><strong>Mark Scheme:</strong></p>
                <div class="quiz-feedback-explanation saq-explanation">${question.explanation}</div>
              </div>
            </div>
            <div style="display: flex; justify-content: flex-end; width: 100%;">
              <button type="button" class="quiz-answer-button saq-answer-button">View answer</button>
            </div>
          </div>
        </div>
      `;

      const answerButton = card.querySelector<HTMLButtonElement>('.saq-answer-button');
      const feedback = card.querySelector<HTMLDivElement>('.quiz-feedback');

      if (answerButton && feedback) {
        // Render any LaTeX in the SAQ card
        if (typeof (window as any).renderMath === 'function') {
          (window as any).renderMath(card);
        }
        
        answerButton.addEventListener('click', () => {
          const isHidden = feedback.classList.contains('hidden');
          if (isHidden) {
            feedback.classList.remove('hidden');
            answerButton.textContent = 'Hide answer';
            answerButton.style.background = 'rgba(52, 211, 153, 0.1)';
          } else {
            feedback.classList.add('hidden');
            answerButton.textContent = 'View answer';
            answerButton.style.background = 'transparent';
          }
        });
      }

      return card;
    }

    const optionsHtml = question.options
      .map((option) => {
        const token = option.value.length <= 2 ? option.value.toUpperCase() : option.label.charAt(0).toUpperCase();
        return `
          <button type="button" class="quiz-option" data-value="${option.value}">
            <span class="quiz-option-token">${token}</span>
          </button>
        `;
      })
      .join('');

    const optionListHtml = question.options
      .map((option) => {
        const token = option.value.length <= 2 ? `${option.value.toUpperCase()}.` : '';
        return `<li><strong>${token}</strong> ${option.label}</li>`;
      })
      .join('');

    card.innerHTML = `
      <div class="quiz-card-shell">
        <div class="quiz-card-top">
          <div class="quiz-number-badge">${questionNumber}</div>
          <div class="quiz-mark-badge">${marks}</div>
        </div>
        <div class="quiz-card-divider"></div>
        <div class="quiz-card-body">
          <div class="quiz-card-question">${question.prompt}</div>
          <ul class="quiz-choice-list">
            ${optionListHtml}
          </ul>
        </div>
        <div class="quiz-card-footer">
          <p class="quiz-answer-label">Choose your answer</p>
          <div class="quiz-options" role="list">
            ${optionsHtml}
          </div>
          <div class="quiz-feedback hidden" aria-live="polite">
            <div class="quiz-feedback-main">
              <div class="quiz-feedback-badge"></div>
              <p class="quiz-feedback-answer">Correct answer: <strong>${question.answerLabel}</strong></p>
              <p class="quiz-feedback-explanation">${question.explanation}</p>
            </div>
            <button type="button" class="quiz-answer-button">View answer</button>
          </div>
        </div>
      </div>
    `;

    const options = Array.from(card.querySelectorAll<HTMLButtonElement>('.quiz-option'));
    const feedback = card.querySelector<HTMLDivElement>('.quiz-feedback');
    const feedbackBadge = card.querySelector<HTMLDivElement>('.quiz-feedback-badge');
    const answerButton = card.querySelector<HTMLButtonElement>('.quiz-answer-button');

    if (answerButton) {
      answerButton.disabled = true;
    }

    options.forEach((option) => {
      option.addEventListener('click', () => {
        if (!feedback || !feedbackBadge || card.dataset.answered === 'true') {
          return;
        }

        const selectedValue = option.dataset.value || '';
        const isCorrect = normalizeAnswerValue(selectedValue) === normalizeAnswerValue(question.correctValue);
        card.dataset.answered = 'true';

        options.forEach((button) => {
          const buttonValue = button.dataset.value || '';
          const buttonIsCorrect = normalizeAnswerValue(buttonValue) === normalizeAnswerValue(question.correctValue);
          button.disabled = true;
          button.classList.add('is-locked');

          if (buttonIsCorrect) {
            button.classList.add('is-correct');
          }

          if (button === option && !buttonIsCorrect) {
            button.classList.add('is-incorrect');
          }
        });

        feedback.classList.remove('hidden');
        feedback.classList.toggle('is-correct', isCorrect);
        feedback.classList.toggle('is-incorrect', !isCorrect);
        feedbackBadge.textContent = isCorrect ? 'Correct' : 'Not quite';

        if (answerButton) {
          answerButton.disabled = false;
          answerButton.classList.add('is-active');
          answerButton.addEventListener('click', () => {
             const isHidden = feedback.classList.contains('hidden');
             if (isHidden) {
               feedback.classList.remove('hidden');
               answerButton.textContent = 'Hide answer';
               answerButton.style.background = 'rgba(52, 211, 153, 0.1)';
             } else {
               feedback.classList.add('hidden');
               answerButton.textContent = 'View answer';
               answerButton.style.background = 'transparent';
             }
          });
          answerButton.textContent = 'Hide answer';
          answerButton.style.background = 'rgba(52, 211, 153, 0.1)';
        }
      });
    });

    // Render any LaTeX in the MCQ card
    if (typeof (window as any).renderMath === 'function') {
      (window as any).renderMath(card);
    }

    return card;
  }

  function initQuizCards() {
    const quizContent = document.querySelector('#tab-quiz .markdown-content') || document.querySelector('.tab-content#tab-quiz .markdown-content');
    console.log('[Quiz] quizContent found:', !!quizContent);
    if (!quizContent) {
      // Try all markdown-content elements
      const allContent = document.querySelectorAll('.markdown-content');
      console.log('[Quiz] All markdown-content elements:', allContent.length);
      for (const el of allContent) {
        const parent = el.closest('.tab-content');
        console.log('[Quiz] Content parent ID:', parent?.id);
      }
    }
    console.log('[Quiz] Starting initQuizCards');
    if (!(quizContent instanceof HTMLElement) || quizContent.dataset.enhanced === 'true') {
      console.log('[Quiz] Returning early, enhanced:', quizContent?.dataset?.enhanced);
      return;
    }

    const children = Array.from(quizContent.children);
    console.log('[Quiz] Children count:', children.length);
    const fragment = document.createDocumentFragment();
    const interactiveQuestions: ReturnType<typeof parseQuizBlock>[] = [];

    for (let index = 0; index < children.length; index += 1) {
      const node = children[index];
      console.log('[Quiz] Node:', node.tagName);

      if (node.tagName === 'H3') {
        const blockNodes = [node];
        let nextIndex = index + 1;

        while (nextIndex < children.length && children[nextIndex].tagName !== 'H3') {
          blockNodes.push(children[nextIndex]);
          nextIndex += 1;
        }

        const parsedQuestion = parseQuizBlock(blockNodes);
        if (parsedQuestion) {
          interactiveQuestions.push(parsedQuestion);
          fragment.append(buildQuizCard(parsedQuestion));
          index = nextIndex - 1;
          continue;
        }
      }

      if (node.tagName === 'HR') {
        continue;
      }

      fragment.append(node.cloneNode(true));
    }

    quizContent.innerHTML = '';

    if (interactiveQuestions.length > 0) {
      const introCard = document.createElement('section');
      introCard.className = 'quiz-intro card';
      introCard.innerHTML = `
        <div class="quiz-intro-copy">
          <span class="quiz-intro-kicker">Interactive quiz mode</span>
          <h3 class="quiz-intro-title">Tap an answer to reveal the explanation instantly.</h3>
          <p class="quiz-intro-text">${interactiveQuestions.length} questions were upgraded with instant feedback so you can check the reasoning right away.</p>
        </div>
      `;
      quizContent.append(introCard);
    }

    quizContent.append(fragment);
    quizContent.dataset.enhanced = 'true';
    quizContent.classList.add('quiz-enhanced');
  }
  
  // Run on page load
  initTabs();
  initQuizCards();
</script>

