                                      {group.markSchemes.map((paper) => (
                                        <a href={paper.href} target="_blank" rel="noreferrer" class="paper-link ms" title={paper.fileName}>
                                          <span class="link-label">{paper.assetLabel}</span>
                                        </a>
                                      ))}
                                      {group.examinerReports.map((paper) => (
                                        <a href={paper.href} target="_blank" rel="noreferrer" class="paper-link er" title={paper.fileName}>
                                          <span class="link-label">{paper.assetLabel}</span>
                                        </a>
                                      ))}
                                    </div>
                                  </div>
                                ))}
                              </div>
