    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--app-surface-muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .practice-link-action {
    font-size: 1rem;
    color: var(--app-accent);
    font-weight: 700;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .practice-link-card.external-link {
    border-color: var(--app-accent);
    background: color-mix(in srgb, var(--app-accent) 6%, var(--app-surface));
  }

  /* Past Papers Container */
  .past-papers-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .past-papers-toolbar {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .past-papers-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--app-border);
    border-radius: 1rem;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--app-accent) 18%, transparent), transparent 42%),
      linear-gradient(180deg, var(--app-surface), var(--app-surface-muted));
  }

  .past-papers-eyebrow {
    margin: 0 0 0.25rem;
    color: var(--app-accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .past-papers-copy {
    margin: 0;
    color: var(--app-text-muted);
    font-size: 0.95rem;
  }

  .past-papers-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .past-papers-metric {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 7rem;
    padding: 0.65rem 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--app-accent) 25%, var(--app-border));
    background: color-mix(in srgb, var(--app-accent) 10%, var(--app-surface));
    color: var(--app-text);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .paper-filter-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .paper-filter-chip {
    appearance: none;
    border: 1px solid color-mix(in srgb, var(--app-accent) 22%, var(--app-border));
    background: var(--app-surface);
    color: var(--app-text);
    padding: 0.7rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .paper-filter-chip:hover,
  .paper-filter-chip.active {
    background: color-mix(in srgb, var(--app-accent) 12%, var(--app-surface));
    border-color: color-mix(in srgb, var(--app-accent) 55%, var(--app-border));
    transform: translateY(-1px);
  }

  .paper-filter-state {
    color: var(--app-text-muted);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .year-section {
    background: var(--app-surface-muted);
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--app-border);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
  }

  .year-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    background: linear-gradient(135deg, var(--app-accent) 0%, color-mix(in srgb, var(--app-accent) 65%, black) 100%);
  }

  .year-title {
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
  }

  .year-count {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .papers-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.4rem;
  }

  .paper-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .paper-name {
    font-weight: 600;
    color: var(--app-text);
    font-size: 1rem;
  }

  .paper-subtitle {
    color: var(--app-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .paper-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1rem;
    border-radius: 0.85rem;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .paper-row:hover {
    background: var(--app-surface);
    transform: translateY(-1px);
  }

  .paper-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .paper-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s ease;
    border: 2px solid;
  }

  .paper-link.qp {
    background: transparent;
    color: #3b82f6;
    border-color: #3b82f6;
  }

  .paper-link.qp:hover {
    background: #3b82f6;
    color: white;
  }

  .paper-link.ms {
    background: transparent;
    color: #22c55e;
    border-color: #22c55e;
  }

  .paper-link.ms:hover {
    background: #22c55e;
    color: white;
  }

  .paper-link.er {
    background: transparent;
    color: #f59e0b;
    border-color: #f59e0b;
  }

  .paper-link.er:hover {
    background: #f59e0b;
    color: white;
  }

  .link-label {
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .past-papers-summary,
    .year-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .past-papers-metrics,
    .paper-links {
      width: 100%;
    }

    .paper-link {
      flex: 1 1 0;
      min-width: 0;
      justify-content: space-between;
    }
  }

  /* Markdown Content Styling */
  .markdown-content {
    font-size: 1.4rem;
    line-height: 1.6;
    color: var(--app-text);
  }

  .markdown-content :global(h1) { font-size: 2.5rem; margin: 2rem 0 1rem; color: var(--app-accent); position: relative; display: inline-block; }
  .markdown-content :global(h1::after) { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 3px; background: var(--app-accent); opacity: 0.3; }
  
  .markdown-content :global(h2) { font-size: 2rem; margin: 1.5rem 0 0.75rem; color: var(--app-text); }
  .markdown-content :global(h3) { font-size: 1.65rem; margin: 1.25rem 0 0.5rem; color: var(--app-text-muted); }
  
  .markdown-content :global(p) { margin-bottom: 1.25rem; }
  
  .markdown-content :global(ul), .markdown-content :global(ol) { margin: 1rem 0 1.5rem 2rem; }
  .markdown-content :global(li) { margin-bottom: 0.5rem; }
  
  .markdown-content :global(table) { width: 100%; border-collapse: collapse; margin: 2rem 0; border: 2px solid var(--app-border); border-radius: 1rem; overflow: hidden; }
  .markdown-content :global(th), .markdown-content :global(td) { padding: 0.75rem 1rem; border: 1px solid var(--app-border); text-align: left; }
  .markdown-content :global(th) { background: var(--app-surface-muted); font-weight: 700; }

  .markdown-content :global(strong) { color: var(--app-accent-text); }
  .markdown-content :global(.tikz-diagram) {
    margin: 1.5rem 0 2rem;
    padding: 1rem;
    border: 1px solid var(--app-border);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, var(--app-surface), var(--app-surface-muted));
    overflow-x: auto;
  }
  .markdown-content :global(.tikz-diagram svg) {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    height: auto;
    --tikz-fg: #111827;
  }
  .markdown-content :global(.tikz-diagram svg text) {
    fill: var(--tikz-fg) !important;
  }
  .markdown-content :global(.tikz-diagram svg [stroke="#000"]) {
    stroke: var(--tikz-fg) !important;
  }
  .markdown-content :global(.tikz-diagram svg path:not([fill="none"])) {
    fill: var(--tikz-fg) !important;
  }
  .markdown-content :global(.tikz-diagram svg polygon:not([fill="none"])) {
    fill: var(--tikz-fg) !important;
  }

  .markdown-content :global(.needs-diagram) {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border: 2px dashed #f59e0b !important;
    border-radius: 1rem;
    padding: 1.5rem;
    margin: 1.5rem 0;
    position: relative;
  }

  :global([data-theme='dark']) .markdown-content :global(.needs-diagram) {
    background: linear-gradient(135deg, #451a03 0%, #78350f 100%);
    border-color: #f59e0b !important;
  }

  .markdown-content :global(.needs-diagram)::before {
    content: "📊 Diagram Needed";
    display: block;
    font-weight: 700;
    font-size: 1.1rem;
    color: #92400e;
    margin-bottom: 0.75rem;
  }

  :global([data-theme='dark']) .markdown-content :global(.needs-diagram)::before {
    color: #fbbf24;
  }

  .markdown-content :global(.needs-diagram p) {
    color: #78350f !important;
    font-style: italic;
  }

  :global([data-theme='dark']) .markdown-content :global(.needs-diagram p) {
    color: #fde68a !important;
  }
  :global(html[data-theme='dark']) .markdown-content :global(.tikz-diagram svg) {
    --tikz-fg: #ffffff;
  }

  :global(.quiz-enhanced) {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.quiz-intro) {
    position: relative;
    overflow: hidden;
    padding: 1.5rem;
    border-width: 2px;
    border-radius: 2rem;
    background: linear-gradient(135deg, var(--app-surface), var(--app-surface-muted));
    border-color: rgba(34, 197, 94, 0.3);
  }

  :global(.quiz-intro-kicker) {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.15);
    color: var(--app-accent);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  :global(.quiz-intro-title) {
    margin: 0.9rem 0 0.45rem;
    font-size: clamp(1.8rem, 3vw, 2.45rem);
    color: var(--app-text);
  }

  :global(.quiz-intro-text) {
    margin: 0;
    color: var(--app-text-muted);
    font-size: 1rem;
    line-height: 1.5;
    font-weight: 700;
  }

  :global(.quiz-card) {
    padding: 0;
    border-width: 2px;
    border-radius: 1.9rem;
    background: var(--app-surface);
    border-color: var(--app-border);
    color: var(--app-text);
  }

  :global(.quiz-card-shell) {
    display: flex;
    flex-direction: column;
  }

  :global(.quiz-card-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.45rem 1.6rem 1rem;
  }

  :global(.quiz-number-badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 999px;
    background: var(--app-accent);
    color: white;
    font-size: 1.25rem;
    font-weight: 700;
  }

  :global(.quiz-mark-badge) {
    color: var(--app-text-muted);
    font-size: 1.2rem;
    font-weight: 500;
  }

  :global(.quiz-card-divider) {
    height: 1px;
    margin: 0 1.6rem;
    background: var(--app-border);
  }

  :global(.quiz-card-body) {
    padding: 1.8rem 1.6rem 2.8rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.quiz-card-question) {
    margin: 1.5rem 0 1.5rem;
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    line-height: 1.4;
    color: var(--app-text);
    font-weight: 500;
  }

  :global(.quiz-choice-list) {
    margin: 0;
    padding-left: 2.9rem;
    display: grid;
    gap: 0.8rem;
    list-style: none;
  }

  :global(.quiz-choice-list li) {
    color: var(--app-text);
    font-size: 1.35rem;
    line-height: 1.5;
  }

  :global(.quiz-choice-list strong) {
    color: var(--app-text);
    margin-right: 0.5rem;
    font-weight: 700;
  }

  :global(.quiz-card-footer) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.4rem 1.6rem 1.6rem;
    border-top: 1px solid var(--app-border);
  }

  :global(.quiz-answer-label) {
    margin: 0;
    color: var(--app-text);
    font-size: 1.2rem;
    font-weight: 700;
  }

  :global(.quiz-options) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  :global(.quiz-option) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    padding: 0;
    border-radius: 999px;
    border: 2px solid var(--app-border);
    background: var(--app-surface-muted);
    color: var(--app-text);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    font: inherit;
  }

  :global(.quiz-option:hover) {
    transform: translateY(-2px);
    border-color: var(--app-accent);
    background: color-mix(in srgb, var(--app-accent) 15%, var(--app-surface-muted));
  }

  :global(.quiz-option:disabled) {
    cursor: default;
  }

  :global(.quiz-option-token) {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--app-accent);
  }

  :global(.quiz-option.is-correct) {
    border-color: #34D399;
    background: #34D399;
    color: white;
  }

  :global(.quiz-option.is-correct .quiz-option-token) {
    color: white;
  }

  :global(.quiz-option.is-incorrect) {
    border-color: #ef4444;
    background: #ef4444;
    color: white;
  }

  :global(.quiz-option.is-incorrect .quiz-option-token) {
    color: white;
  }

  :global(.quiz-option.is-locked:not(.is-correct):not(.is-incorrect)) {
    opacity: 0.6;
  }

  :global(.quiz-feedback) {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--app-border);
  }

  :global(.quiz-feedback.is-correct) {
    color: #166534;
  }

  :global(.quiz-feedback.is-incorrect) {
    color: #991b1b;
  }

  :global(.quiz-feedback-main) {
    display: grid;
    gap: 0.45rem;
  }

  :global(.quiz-feedback-badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 2rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.15);
    color: #166534;
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  :global(.quiz-feedback-answer),
  :global(.quiz-feedback-explanation) {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
  }

  :global(.quiz-feedback-answer) {
    color: var(--app-text);
    font-weight: 800;
  }

  :global(.quiz-feedback-explanation) {
    color: var(--app-text-muted);
    font-weight: 700;
    max-width: 52rem;
  }

  :global(.quiz-answer-button) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 10rem;
    min-height: 3.2rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    background: transparent;
    border: 2px solid var(--app-accent);
    color: var(--app-accent);
    font-size: 1rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  :global(.quiz-answer-button:hover:not(:disabled)) {
    background: color-mix(in srgb, var(--app-accent) 15%, transparent);
  }

  :global(.quiz-answer-button:disabled) {
    opacity: 0.55;
  }

  :global(.quiz-feedback.hidden) {
    display: none;
  }

  :global(.quiz-answer-button.is-active) {
    opacity: 1;
  }

  :global(.quiz-answer-button.is-active:disabled) {
    opacity: 0.55;
  }

  @media (max-width: 640px) {
    :global(.quiz-card),
    :global(.quiz-intro) {
      padding: 1.15rem;
      border-radius: 1.6rem;
    }

    :global(.quiz-option) {
      width: 3.75rem;
      height: 3.75rem;
    }

    :global(.quiz-option-token) {
      font-size: 1.75rem;
    }

    :global(.quiz-choice-list) {
      padding-left: 1.4rem;
    }

    :global(.quiz-choice-list li) {
      font-size: 1.2rem;
    }

    :global(.quiz-feedback) {
      flex-direction: column;
      align-items: stretch;
    }

    :global(.quiz-answer-button) {
      width: 100%;
      min-width: 0;
    }
  }

  .practice-link-card {
    border: 1px solid var(--app-border);
    border-left: 5px solid var(--accent-color);
  }

  .papers-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .papers-container {
      grid-template-columns: 1fr 1fr;
    }
  }

  .papers-column {
    border: 1px solid var(--app-border);
    padding: 1rem;
    border-radius: 1rem;
  }

  .column-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .practice-link-icon {
    background: color-mix(in srgb, var(--accent-color) 14%, white);
    color: var(--accent-color);
  }

  .debug-info { display: block; background: #eee; padding: 1rem; margin: 1rem 0; color: #111 }
:global([data-theme='dark']) .debug-info { background: #333; color: #fff; }
