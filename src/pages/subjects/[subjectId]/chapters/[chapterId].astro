</Layout>

<script>
  console.log('[Quiz] Script tag loaded');
  // Tab switching logic
  function initTabs() {
    const tabButtons = document.querySelectorAll('.tab-item[data-tab]');
    const tabContents = document.querySelectorAll('.tab-content');
    
    // Get initial tab from URL or default to notes
    const urlParams = new URLSearchParams(window.location.search);
    let activeTab = urlParams.get('tab') || 'notes';
    
    function setActiveTab(tabId: string) {
      // Update buttons
      tabButtons.forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-tab') === tabId);
      });
      
      // Update content
      tabContents.forEach(content => {
        content.classList.toggle('hidden', content.id !== `tab-${tabId}`);
      });
      
      // Update URL
      const url = new URL(window.location.href);
      if (tabId === 'notes') {
        url.searchParams.delete('tab');
      } else {
        url.searchParams.set('tab', tabId);
      }
      window.history.replaceState({}, '', url.toString());
    }
    
    // Initialize
    setActiveTab(activeTab);
    
    // Add click handlers
    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        if (tabId) {
          setActiveTab(tabId);
        }
      });
    });
  }

  function stripWrappedQuotes(value: string) {
    return value.replace(/^["']|["']$/g, '').trim();
  }

  function isSectionHeader(text: string): boolean {
    const normalized = text.replace(/\*/g, '').replace(/\[[^\]]+\]/g, '').trim();
    return /^(part\s+[a-z]|multiple choice|true[\/\s]*(or|and)\s*false|short answer|extended answer)/i.test(normalized);
  }

  function isQuestionHeading(text: string): boolean {
    const normalized = text.replace(/\*/g, '').replace(/\[[^\]]+\]/g, '').trim();
    return /^(question|statement)\s+\d+/i.test(normalized);
  }

  function isQuestionStartNode(node: Element): boolean {
    if (node.tagName === 'H2' || node.tagName === 'H3') {
      const text = node.textContent?.trim() || '';
      return isQuestionHeading(text);
    }
    return false;
  }

  function isOptionLine(text: string): boolean {
    return /^[A-Z][\)\.]\s+/.test(text);
  }

  function getLeadingLabel(text: string): string {
    const match = text.match(/^([A-Z])[\)\.]\s+/);
    return match ? match[1] : '';
  }

  function stripLeadingLabel(text: string): string {
    return text.replace(/^[A-Z][\)\.]\s+/, '').trim();
  }

  function normalizeAnswerValue(value: string): string {
    return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
  }

  function stripHtmlTags(value: string): string {
    const temp = document.createElement('div');
    temp.innerHTML = value;
    return temp.textContent?.trim() || '';
  }

  function parseAnswerLine(text: string): { value: string; raw: string } {
    const normalizedText = stripHtmlTags(text) || text;
    const cleanText = normalizedText.replace(/\*/g, '').trim().toUpperCase();
    
    if (/^(TRUE|FALSE)/.test(cleanText)) {
      const match = cleanText.match(/^(TRUE|FALSE)/);
      return { value: match ? match[0] : '', raw: normalizedText };
    }

    const extracted = normalizedText
      .replace(/\*\*/g, '')
      .replace(/^[\s]*answer:\s*/i, '')
      .replace(/^[\s]*correct answer:\s*/i, '')
      .replace(/\s*$/, '')
      .trim();

    return { value: extracted, raw: extracted };
  }

  function parseExplanation(text: string): string {
    const normalizedText = stripHtmlTags(text) || text;
    return normalizedText
      .replace(/\*\*/g, '')
      .replace(/^(explanation|correction):\s*/i, '')
      .replace(/^mark scheme:\s*/i, '')
      .trim();
  }

  function parseMarkScheme(text: string): string {
    const normalizedText = stripHtmlTags(text) || text;
    return normalizedText
      .replace(/\*\*/g, '')
      .replace(/^mark scheme:?\s*/i, '')
      .trim();
  }

  function extractOptionsFromContent(nodes: Element[]): { options: Array<{value: string; label: string}>; promptEndIndex: number } {
    const options: Array<{value: string; label: string}> = [];
    const optionPattern = /^([A-Z])[\)\.]\s+(.+)/;
    
    function processText(text: string): void {
      const lines = text.split(/\n|<br\s*\/?>/i).map(l => l.trim()).filter(l => l);
      for (const line of lines) {
        const match = line.match(optionPattern);
        if (match) {
          options.push({ value: match[1].toUpperCase(), label: match[2].trim() });
        }
      }
    }
    
    for (let i = 0; i < nodes.length; i++) {
      const node = nodes[i];
      
      if (node.tagName === 'P') {
        const html = node.innerHTML;
        const text = node.textContent || '';
        const normalizedText = text.replace(/\s+/g, ' ').trim();
        if (optionPattern.test(normalizedText) || /^([A-Z][\)\.]\s*.){2}/.test(normalizedText)) {
          processText(html);
          continue;
        }
      }
      
      if (node.tagName === 'UL' || node.tagName === 'OL') {
        const listItems = Array.from(node.querySelectorAll('li'));
        let foundOptionInList = false;
        
        for (const li of listItems) {
          const html = li.innerHTML;  // Use innerHTML to preserve LaTeX
          const text = html.replace(/\s+/g, ' ').trim();
          const match = text.match(/^([A-Z])[\)\.]\s+(.+)/);
          if (match) {
            options.push({ value: match[1].toUpperCase(), label: match[2].trim() });
            foundOptionInList = true;
          }
        }
        
        if (foundOptionInList) continue;
      }
      
      if (node.tagName === 'TABLE') {
        const rows = node.querySelectorAll('tr');
        for (const row of rows) {
          const cells = row.querySelectorAll('td, th');
          for (const cell of cells) {
            const html = cell.innerHTML;  // Use innerHTML to preserve LaTeX
            const text = html.replace(/\s+/g, ' ').trim();
            const match = text.match(/^([A-Z])[\)\.]\s+(.+)/);
            if (match) {
              options.push({ value: match[1].toUpperCase(), label: match[2].trim() });
            }
          }
        }
        if (options.length > 0) continue;
      }
      
      const cleanText = stripHtmlTags(node.innerHTML);
      if (/^answer:\s*(true|false)/i.test(cleanText) || /^correct answer:\s*(true|false)/i.test(cleanText)) {
        break;
      }
      if (/^answer:\s*/i.test(cleanText) || /^correct answer:\s*/i.test(cleanText)) {
        break;
      }
    }
    
    return { options, promptEndIndex: -1 };
  }

  function parseQuizBlock(nodes: Element[]): any {
    const heading = nodes[0];
    const headingText = heading.textContent?.trim() || '';
    const contentNodes = nodes.slice(1);
    
    const isStatementTF = /statement\s*\d+/i.test(headingText);
    const isSAQ = /mark scheme/i.test(headingText) || contentNodes.some(n => 
      /^[\s\*]*mark scheme/i.test(stripHtmlTags(n.innerHTML))
    );

    if (isSAQ && !isStatementTF) {
      const markSchemeIndex = contentNodes.findIndex(n => 
        /^[\s\*]*mark scheme/i.test(stripHtmlTags(n.innerHTML))
      );
      
      if (markSchemeIndex !== -1) {
        const promptHtml = contentNodes.slice(0, markSchemeIndex).map(n => n.outerHTML).join('');
        const explanationHtml = contentNodes.slice(markSchemeIndex).map(n => {
          const text = stripHtmlTags(n.innerHTML);
          if (/^mark scheme/i.test(text)) {
            return parseMarkScheme(text);
          }
          return n.outerHTML;
        }).join('<br>');
        
        return {
          isSAQ: true,
          heading: headingText,
          prompt: promptHtml,
          options: [],
          correctValue: '',
          answerLabel: 'Mark Scheme',
          answerLabelHtml: 'Mark Scheme',
          explanation: explanationHtml,
        };
      }
    }

    const textLines: string[] = [];
    const htmlLines: string[] = [];
    
    for (const node of contentNodes) {
      if (['P', 'LI', 'TH', 'TD'].includes(node.tagName)) {
        textLines.push(stripHtmlTags(node.innerHTML));
        htmlLines.push(node.innerHTML);
      } else if (node.tagName === 'UL' || node.tagName === 'OL') {
        for (const li of Array.from(node.children)) {
          textLines.push(stripHtmlTags(li.innerHTML));
          htmlLines.push(li.innerHTML);
        }
      }
    }

    let answerIndex = -1;
    let explanationIndex = -1;
    let markSchemeIndex = -1;
    let isTrueFalseAnswer = false;
    
    for (let i = 0; i < textLines.length; i++) {
      const text = textLines[i].replace(/\*/g, '');
      if (/^answer:\s*(true|false)/i.test(text) || /^correct answer:\s*(true|false)/i.test(text)) {
        if (answerIndex === -1) {
          answerIndex = i;
          isTrueFalseAnswer = true;
        }
      }
      if (/^answer:\s*[a-z]/i.test(text) && !/^answer:\s*(true|false)/i.test(text)) {
        if (answerIndex === -1) answerIndex = i;
      }
      if (/^explanation:/i.test(text) || /^correction:/i.test(text)) {
        if (explanationIndex === -1) explanationIndex = i;
      }
      if (/^mark scheme/i.test(text)) {
        if (markSchemeIndex === -1) markSchemeIndex = i;
      }
    }

    const { options } = extractOptionsFromContent(contentNodes);
    const hasMCQOptions = options.length >= 2;
    
    if (answerIndex === -1 && !isStatementTF && !hasMCQOptions) {
      return null;
    }

    let correctValue = '';
    let answerLabel = '';
    let answerLabelHtml = '';
    
    if (answerIndex !== -1) {
      const { value } = parseAnswerLine(textLines[answerIndex]);
      if (isTrueFalseAnswer) {
        correctValue = normalizeAnswerValue(value);
        answerLabel = correctValue.charAt(0).toUpperCase() + correctValue.slice(1);
        answerLabelHtml = answerLabel;
      } else {
        const match = value.match(/^[A-Z]/);
        correctValue = match ? match[0].toUpperCase() : '';
        answerLabel = textLines[answerIndex].replace(/\*\*/g, '').replace(/^answer:\s*/i, '').replace(/^correct answer:\s*/i, '').trim();
        answerLabelHtml = htmlLines[answerIndex]?.replace(/\*\*/g, '').replace(/^[\s]*answer:\s*/i, '').replace(/^[\s]*correct answer:\s*/i, '').trim() || answerLabel;
      }
    }

    let promptEndIndex = answerIndex !== -1 ? answerIndex : (explanationIndex !== -1 ? explanationIndex : textLines.length);
    if (markSchemeIndex !== -1 && markSchemeIndex < promptEndIndex) {
      promptEndIndex = markSchemeIndex;
    }
    
    const optionLinePattern = /^([A-Z])[\)\.]\s+/;
    const isTrueFalseQuestion = isTrueFalseAnswer || isStatementTF;
    const promptHtmlParts: string[] = [];
    for (let i = 0; i < promptEndIndex && i < htmlLines.length; i++) {
      const textLine = textLines[i] || '';
      const normalizedLine = textLine.replace(/\s+/g, ' ').trim();
      if (isTrueFalseQuestion || !optionLinePattern.test(normalizedLine)) {
        promptHtmlParts.push(htmlLines[i]);
      }
    }
    const promptHtml = promptHtmlParts.join('');
    
    let explanationHtml = 'Review the chapter notes for the reasoning.';
    if (explanationIndex !== -1) {
      explanationHtml = htmlLines.slice(explanationIndex).map((t, i) => i === 0 ? parseExplanation(t) : t).join('<br>');
    } else if (markSchemeIndex !== -1) {
      explanationHtml = htmlLines.slice(markSchemeIndex).map((t, i) => i === 0 ? parseMarkScheme(t) : t).join('<br>');
    }

    if ((isTrueFalseAnswer || isStatementTF) && !hasMCQOptions) {
      return {
        isTrueFalse: true,
        heading: headingText,
        prompt: promptHtml,
        options: [
          { value: 'true', label: 'True' },
          { value: 'false', label: 'False' },
        ],
        correctValue,
        answerLabel,
        answerLabelHtml: answerLabelHtml || answerLabel,
        explanation: explanationHtml,
      };
    }

    const validOptions = options.filter(o => o.value && o.label);
    
    if (validOptions.length < 2 && correctValue.length === 0) {
      return null;
    }

    return {
      heading: headingText,
      prompt: promptHtml,
      options: validOptions,
      correctValue,
      answerLabel,
      answerLabelHtml,
      explanation: explanationHtml,
    };
  }

  function buildQuizCard(question: {
    isSAQ?: boolean;
    heading: string;
    prompt: string;
    options: Array<{ value: string; label: string }>;
    correctValue: string;
    answerLabel: string;
    answerLabelHtml?: string;
    explanation: string;
  }) {
    const card = document.createElement('article');
    card.className = 'quiz-card card';
    card.dataset.correct = question.correctValue;
    const numberMatch = question.heading.match(/(\d+)/);
    const questionNumber = numberMatch ? numberMatch[1] : '1';
    const markMatch = question.heading.match(/\((\d+)\s*mark/i);
    const marks = markMatch ? `${markMatch[1]} mark${markMatch[1] === '1' ? '' : 's'}` : '1 mark';

    if (question.isSAQ) {
      card.innerHTML = `
        <div class="quiz-card-shell saq-card-shell">
          <div class="quiz-card-top">
            <div class="quiz-number-badge">${questionNumber}</div>
            <div class="quiz-mark-badge">${marks}</div>
          </div>
          <div class="quiz-card-divider"></div>
          <div class="quiz-card-body">
            <div class="quiz-card-question saq-prompt">${question.prompt}</div>
          </div>
          <div class="quiz-card-footer">
            <div class="quiz-feedback hidden" aria-live="polite">
              <div class="quiz-feedback-main">
                <p class="quiz-feedback-answer"><strong>Mark Scheme:</strong></p>
                <div class="quiz-feedback-explanation saq-explanation">${question.explanation}</div>
              </div>
            </div>
            <div style="display: flex; justify-content: flex-end; width: 100%;">
              <button type="button" class="quiz-answer-button saq-answer-button">View answer</button>
            </div>
          </div>
        </div>
      `;

      const answerButton = card.querySelector<HTMLButtonElement>('.saq-answer-button');
      const feedback = card.querySelector<HTMLDivElement>('.quiz-feedback');

      if (answerButton && feedback) {
        // Render any LaTeX in the SAQ card
        if (typeof (window as any).renderMath === 'function') {
          (window as any).renderMath(card);
        }
        
        answerButton.addEventListener('click', () => {
          const isHidden = feedback.classList.contains('hidden');
          if (isHidden) {
            feedback.classList.remove('hidden');
            answerButton.textContent = 'Hide answer';
            answerButton.style.background = 'rgba(52, 211, 153, 0.1)';
          } else {
            feedback.classList.add('hidden');
            answerButton.textContent = 'View answer';
            answerButton.style.background = 'transparent';
          }
        });
      }

      return card;
    }

    const optionsHtml = question.options
      .map((option) => {
        const token = option.value.length <= 2 ? option.value.toUpperCase() : option.label.charAt(0).toUpperCase();
        return `
          <button type="button" class="quiz-option" data-value="${option.value}">
            <span class="quiz-option-token">${token}</span>
          </button>
        `;
      })
      .join('');

    const optionListHtml = question.options
      .map((option) => {
        const token = option.value.length <= 2 ? `${option.value.toUpperCase()}.` : '';
        return `<li><strong>${token}</strong> ${option.label}</li>`;
      })
      .join('');

    card.innerHTML = `
      <div class="quiz-card-shell">
        <div class="quiz-card-top">
          <div class="quiz-number-badge">${questionNumber}</div>
          <div class="quiz-mark-badge">${marks}</div>
        </div>
        <div class="quiz-card-divider"></div>
        <div class="quiz-card-body">
          <div class="quiz-card-question">${question.prompt}</div>
          <ul class="quiz-choice-list">
            ${optionListHtml}
          </ul>
        </div>
        <div class="quiz-card-footer">
          <p class="quiz-answer-label">Choose your answer</p>
          <div class="quiz-options" role="list">
            ${optionsHtml}
          </div>
          <div class="quiz-feedback hidden" aria-live="polite">
            <div class="quiz-feedback-main">
              <div class="quiz-feedback-badge"></div>
              <p class="quiz-feedback-answer">Correct answer: <strong>${question.answerLabelHtml || question.answerLabel}</strong></p>
              <p class="quiz-feedback-explanation">${question.explanation}</p>
            </div>
            <button type="button" class="quiz-answer-button">View answer</button>
          </div>
        </div>
      </div>
    `;

    const options = Array.from(card.querySelectorAll<HTMLButtonElement>('.quiz-option'));
    const feedback = card.querySelector<HTMLDivElement>('.quiz-feedback');
    const feedbackBadge = card.querySelector<HTMLDivElement>('.quiz-feedback-badge');
    const answerButton = card.querySelector<HTMLButtonElement>('.quiz-answer-button');

    if (answerButton) {
      answerButton.disabled = true;
    }

    options.forEach((option) => {
      option.addEventListener('click', () => {
        if (!feedback || !feedbackBadge || card.dataset.answered === 'true') {
          return;
        }

        const selectedValue = option.dataset.value || '';
        const isCorrect = normalizeAnswerValue(selectedValue) === normalizeAnswerValue(question.correctValue);
        card.dataset.answered = 'true';

        options.forEach((button) => {
          const buttonValue = button.dataset.value || '';
          const buttonIsCorrect = normalizeAnswerValue(buttonValue) === normalizeAnswerValue(question.correctValue);
          button.disabled = true;
          button.classList.add('is-locked');

          if (buttonIsCorrect) {
            button.classList.add('is-correct');
          }

          if (button === option && !buttonIsCorrect) {
            button.classList.add('is-incorrect');
          }
        });

        feedback.classList.remove('hidden');
        feedback.classList.toggle('is-correct', isCorrect);
        feedback.classList.toggle('is-incorrect', !isCorrect);
        feedbackBadge.textContent = isCorrect ? 'Correct' : 'Not quite';

        if (answerButton) {
          answerButton.disabled = false;
          answerButton.classList.add('is-active');
          answerButton.addEventListener('click', () => {
             const isHidden = feedback.classList.contains('hidden');
             if (isHidden) {
               feedback.classList.remove('hidden');
               answerButton.textContent = 'Hide answer';
               answerButton.style.background = 'rgba(52, 211, 153, 0.1)';
             } else {
               feedback.classList.add('hidden');
               answerButton.textContent = 'View answer';
               answerButton.style.background = 'transparent';
             }
          });
          answerButton.textContent = 'Hide answer';
          answerButton.style.background = 'rgba(52, 211, 153, 0.1)';
        }
      });
    });

    // Render any LaTeX in the MCQ card
    if (typeof (window as any).renderMath === 'function') {
      (window as any).renderMath(card);
    }

    return card;
  }

  function initQuizCards() {
    const quizContent = document.querySelector('#tab-quiz .markdown-content') || document.querySelector('.tab-content#tab-quiz .markdown-content');
    if (!quizContent || !(quizContent instanceof HTMLElement) || quizContent.dataset.enhanced === 'true') {
      return;
    }

    const children = Array.from(quizContent.children);
    const fragment = document.createDocumentFragment();
    const interactiveQuestions: ReturnType<typeof parseQuizBlock>[] = [];

    function isSectionHeadingNode(node: Element): boolean {
      if (node.tagName === 'H2' || node.tagName === 'H3') {
        const text = node.textContent?.trim() || '';
        return isSectionHeader(text);
      }
      return false;
    }

    for (let index = 0; index < children.length; index += 1) {
      const node = children[index];

      if (isSectionHeadingNode(node)) {
        continue;
      }

      if (isQuestionStartNode(node)) {
        const blockNodes: Element[] = [node];
        let nextIndex = index + 1;

        while (nextIndex < children.length && 
               !isQuestionStartNode(children[nextIndex]) && 
               !isSectionHeadingNode(children[nextIndex]) &&
               children[nextIndex].tagName !== 'HR') {
          blockNodes.push(children[nextIndex]);
          nextIndex += 1;
        }

        const parsedQuestion = parseQuizBlock(blockNodes);
        if (parsedQuestion) {
          interactiveQuestions.push(parsedQuestion);
          fragment.append(buildQuizCard(parsedQuestion));
          index = nextIndex - 1;
          continue;
        }
      }

      if (node.tagName === 'HR') {
        continue;
      }

      fragment.append(node.cloneNode(true));
    }

    quizContent.innerHTML = '';

    if (interactiveQuestions.length > 0) {
      const introCard = document.createElement('section');
      introCard.className = 'quiz-intro card';
      introCard.innerHTML = `
        <div class="quiz-intro-copy">
          <span class="quiz-intro-kicker">Interactive quiz mode</span>
          <h3 class="quiz-intro-title">Tap an answer to reveal the explanation instantly.</h3>
          <p class="quiz-intro-text">${interactiveQuestions.length} question${interactiveQuestions.length === 1 ? '' : 's'} upgraded with instant feedback.</p>
        </div>
      `;
      fragment.prepend(introCard);
    }

    quizContent.append(fragment);
    quizContent.dataset.enhanced = 'true';
    quizContent.classList.add('quiz-enhanced');

    // Render LaTeX in all quiz cards
    setTimeout(() => {
      if (typeof (window as any).renderMath === 'function') {
        (window as any).renderMath(quizContent);
      }
    }, 100);
  }
  
  // Run on page load
  initTabs();
  initQuizCards();
</script>

