---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { getSubjects, getChapter } from '../../../../utils/subjects';
import { contentSubjectConfigs } from '../../../../utils/contentSubjects';

export function getStaticPaths() {
  const subjects = getSubjects();
  const paths: Array<{params: {subjectId: string; chapterId: string}}> = [];
  
  for (const subjectId of Object.keys(subjects)) {
    const subject = subjects[subjectId];
    for (const chapter of subject.chapters) {
      paths.push({
        params: { subjectId, chapterId: chapter.id }
      });
    }
  }
  
  return paths;
}

const { subjectId, chapterId } = Astro.params;
const subjects = getSubjects();
const subject = subjects[subjectId!];
const chapter = getChapter(subjectId!, chapterId!);

if (!subject || !chapter) {
  return Astro.redirect('/subjects');
}

const bannerMap: Record<string, string> = {
  'biology': '/banners/biology.png',
  'chemistry': '/banners/chemistry.png',
  'physics': '/banners/physics.png',
  'maths': '/banners/math.png',
  'ict': '/banners/compsci.png',
};

const bannerSrc = bannerMap[subjectId!] || '';

// Import all chapter content files
const noteModules = import.meta.glob('/src/subjects/*/chapter-*/note.md', { eager: true });
const synopsisModules = import.meta.glob('/src/subjects/*/chapter-*/synopsis.md', { eager: true });
const quizModules = import.meta.glob('/src/subjects/*/chapter-*/quiz.md', { eager: true });
const practiceModules = import.meta.glob('/src/subjects/*/chapter-*/practice.md', { eager: true });
const biologyNoteModules = import.meta.glob('/src/newcontent/Biology/Biology_Chapter*_Notes.md', { eager: true });
const biologySynopsisModules = import.meta.glob('/src/newcontent/Biology/Biology_Chapter*_Synopsis.md', { eager: true });
const biologyQuizModules = import.meta.glob('/src/newcontent/Biology/Biology_Chapter*_Quiz.md', { eager: true });
const chemistryNoteModules = import.meta.glob('/src/newcontent/chemistry/Chemistry_Ch*_Notes.md', { eager: true });
const chemistrySynopsisModules = import.meta.glob('/src/newcontent/chemistry/Chemistry_Ch*_Synopsis.md', { eager: true });
const chemistryQuizModules = import.meta.glob('/src/newcontent/chemistry/Chemistry_Ch*_Quiz.md', { eager: true });
const physicsNoteModules = import.meta.glob('/src/newcontent/physics/Physics_*_Notes.md', { eager: true });
const physicsSynopsisModules = import.meta.glob('/src/newcontent/physics/Physics_*_Synopsis.md', { eager: true });
const physicsQuizModules = import.meta.glob('/src/newcontent/physics/Physics_*_Quiz.md', { eager: true });
const ictNoteModules = import.meta.glob('/src/newcontent/ICT/ICT_Chapter*_Notes.md', { eager: true });
const ictSynopsisModules = import.meta.glob('/src/newcontent/ICT/ICT_Chapter*_Synopsis.md', { eager: true });
const ictQuizModules = import.meta.glob('/src/newcontent/ICT/ICT_Chapter*_Quiz.md', { eager: true });
const mathsNoteModules = import.meta.glob('/src/newcontent/maths/Mathematics_Chapter*_Notes.md', { eager: true });
const mathsSynopsisModules = import.meta.glob('/src/newcontent/maths/Mathematics_Chapter*_Synopsis.md', { eager: true });
const mathsQuizModules = import.meta.glob('/src/newcontent/maths/Mathematics_Chapter*_Quiz.md', { eager: true });

// Find the content for this chapter
const isBiology = subjectId === 'biology';
const isChemistry = subjectId === 'chemistry';
const isPhysics = subjectId === 'physics';
const isIct = subjectId === 'ict';
const isMaths = subjectId === 'maths';

const contentSubjectConfig = isBiology
  ? contentSubjectConfigs.biology
  : isChemistry
    ? contentSubjectConfigs.chemistry
    : isPhysics
      ? contentSubjectConfigs.physics
      : isIct
        ? contentSubjectConfigs.ict
        : isMaths
          ? contentSubjectConfigs.maths
          : null;
const chapterPathParam = isMaths ? chapter.id.replace('chapter-', '') : chapter.number;
const notePath = contentSubjectConfig
  ? contentSubjectConfig.notePath(chapterPathParam)
  : `/src/subjects/${subjectId}/${chapterId}/note.md`;
const synopsisPath = contentSubjectConfig
  ? contentSubjectConfig.synopsisPath(chapterPathParam)
  : `/src/subjects/${subjectId}/${chapterId}/synopsis.md`;
const quizPath = contentSubjectConfig
  ? contentSubjectConfig.quizPath(chapterPathParam)
  : `/src/subjects/${subjectId}/${chapterId}/quiz.md`;
const practicePath = `/src/subjects/${subjectId}/${chapterId}/practice.md`;

const contentNoteModules = isBiology
  ? biologyNoteModules
  : isChemistry
    ? chemistryNoteModules
    : isPhysics
      ? physicsNoteModules
      : isIct
        ? ictNoteModules
        : isMaths
          ? mathsNoteModules
          : noteModules;
const contentSynopsisModules = isBiology
  ? biologySynopsisModules
  : isChemistry
    ? chemistrySynopsisModules
    : isPhysics
      ? physicsSynopsisModules
      : isIct
        ? ictSynopsisModules
        : isMaths
          ? mathsSynopsisModules
          : synopsisModules;
const contentQuizModules = isBiology
  ? biologyQuizModules
  : isChemistry
    ? chemistryQuizModules
    : isPhysics
      ? physicsQuizModules
      : isIct
        ? ictQuizModules
        : isMaths
          ? mathsQuizModules
          : quizModules;

const noteModule = contentNoteModules[notePath] as any;
const synopsisModule = contentSynopsisModules[synopsisPath] as any;
const quizModule = contentQuizModules[quizPath] as any;
const practiceModule = practiceModules[practicePath] as any;

const pastPaperContentModules = import.meta.glob('/src/newpastpapers/*.md', { query: '?raw', import: 'default', eager: true }) as Record<string, string>;

const variantRank: Record<string, number> = {
  Core: 0,
  Foundation: 1,
  Higher: 2,
  Regional: 3,
};

function parseMathsPastPapers(content: string): PastPaperSession[] {
  const sessionMap = new Map<string, Map<string, PastPaperGroup>>();
  const lines = content.split('\n');
  let currentSession = '';
  let currentPaperType: 'Question Paper' | 'Mark Scheme' | 'Examiner Report' = 'Question Paper';
  
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    
    // Match year headers like "2025"
    const yearOnly = trimmed.match(/^\d{4}$/);
    if (yearOnly) {
      currentPaperType = 'Question Paper';
      continue;
    }
    
    // Match session lines like "- November 2025"
    const sessionMatch = trimmed.match(/^-\s+(November|June|January)\s+\d{4}$/i);
    if (sessionMatch) {
      currentSession = sessionMatch[0].replace(/^-\s+/, '');
      if (!sessionMap.has(currentSession)) {
        sessionMap.set(currentSession, new Map());
      }
      currentPaperType = 'Question Paper';
      continue;
    }
    
    if (trimmed.startsWith('▫')) {
      const lower = trimmed.toLowerCase();
      if (lower.includes('question')) {
        currentPaperType = 'Question Paper';
      } else if (lower.includes('mark')) {
        currentPaperType = 'Mark Scheme';
      } else if (lower.includes('examiner')) {
        currentPaperType = 'Examiner Report';
      }
      continue;
    }
    
    if (!trimmed.startsWith('Paper ')) continue;
    
    const urlMatches = trimmed.match(/https:\/\/[^,\s)]+/g) || [];
    for (const url of urlMatches) {
      if (url.includes('youtubemodal') || url.includes('#')) continue;
      if (!url.includes('.pdf') && !url.includes('_pdf')) continue;
      
      let rawFileName = url.split('/').pop()?.split('?')[0] || 'unknown.pdf';
      rawFileName = rawFileName.replace(/[-–—]\d+[,\s]*$/, '').replace(/[)\]]+$/, '');
      const fileName = rawFileName;
      const lowerUrl = url.toLowerCase();
      
      let paperTypeName = currentPaperType;
      if (lowerUrl.includes('pef')) {
        paperTypeName = 'Examiner Report';
      } else if (lowerUrl.includes('rms') || lowerUrl.includes('msc') || lowerUrl.includes('mark-scheme') || lowerUrl.includes('mark_scheme')) {
        paperTypeName = 'Mark Scheme';
      }
      
      const { label, paperNumber, paperVariant, paperTier } = extractPaperMeta(fileName);
      const { assetLabel, assetPriority } = getAssetMeta(fileName, paperTypeName);
      
      const entry: PastPaperEntry = {
        label,
        href: url,
        fileName,
        session: currentSession,
        sortDate: parseYearAndSessionToDate(currentSession).getTime(),
        paperNumber,
        paperVariant,
        paperTier,
        paperTypeName,
        assetLabel,
        assetPriority,
      };
      
      const sessionGroups = sessionMap.get(currentSession) ?? new Map<string, PastPaperGroup>();
      const existingGroup = sessionGroups.get(label) ?? {
        label,
        paperNumber,
        paperVariant,
        paperTier,
        questionPapers: [],
        markSchemes: [],
        examinerReports: [],
      };
      
      if (paperTypeName === 'Question Paper') {
        if (!existingGroup.questionPapers.some((paper) => paper.fileName === entry.fileName)) {
          existingGroup.questionPapers.push(entry);
        }
      } else if (paperTypeName === 'Examiner Report') {
        if (!existingGroup.examinerReports.some((paper) => paper.fileName === entry.fileName)) {
          existingGroup.examinerReports.push(entry);
        }
      } else if (!existingGroup.markSchemes.some((paper) => paper.fileName === entry.fileName)) {
        existingGroup.markSchemes.push(entry);
      }
      
      sessionGroups.set(label, existingGroup);
      sessionMap.set(currentSession, sessionGroups);
    }
  }
  
  return Array.from(sessionMap.entries())
    .map(([label, groupsMap]) => ({
      label,
      sortDate: parseYearAndSessionToDate(label).getTime(),
      groups: Array.from(groupsMap.values())
        .map((group) => ({
          ...group,
          questionPapers: group.questionPapers.sort((a, b) => a.assetPriority - b.assetPriority || a.fileName.localeCompare(b.fileName)),
          examinerReports: group.examinerReports.sort((a, b) => a.assetPriority - b.assetPriority || a.fileName.localeCompare(b.fileName)),
          markSchemes: group.markSchemes.sort((a, b) => a.assetPriority - b.assetPriority || a.fileName.localeCompare(b.fileName)),
        }))
        .sort((a, b) => {
          if (a.paperNumber !== b.paperNumber) return a.paperNumber - b.paperNumber;
          return (variantRank[a.paperVariant] ?? 99) - (variantRank[b.paperVariant] ?? 99);
        }),
    }))
    .sort((a, b) => b.sortDate - a.sortDate);
}

function parsePastPaperContent(content: string, subjectId: string) {
  if (subjectId === 'maths') {
    return parseMathsPastPapers(content);
  }
  
  const sessionMap = new Map<string, Map<string, PastPaperGroup>>();
  const lines = content.split('\n');
  let currentSession = '';
  
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    
    const sessionMatch = trimmed.match(/^(January|February|March|April|May|June|July|August|September|October|November|December)\s+\d{4}$/i);
    if (sessionMatch) {
      currentSession = trimmed;
      if (!sessionMap.has(currentSession)) {
        sessionMap.set(currentSession, new Map());
      }
      continue;
    }
    
    if (trimmed.startsWith('-')) {
      const urlMatches = trimmed.match(/https:\/\/[^\]]+/g) || [];
      
      for (const url of urlMatches) {
        if (url.includes('youtubemodal') || url.includes('#')) continue;
        if (!url.includes('.pdf')) continue;
        
        const fileName = url.split('/').pop()?.split('?')[0] || 'unknown.pdf';
        const lowerUrl = url.toLowerCase();
        
        if (subjectId === 'ict' && (lowerUrl.includes('-01r-') || lowerUrl.includes('_01r_') || lowerUrl.includes('_01R_') || lowerUrl.includes('-01R-') || lowerUrl.includes('past-paper-redraft') || lowerUrl.includes('changes-for-june'))) continue;
        
        let paperTypeName: 'Question Paper' | 'Mark Scheme' | 'Examiner Report' = 'Question Paper';
        if (lowerUrl.includes('pef')) {
          paperTypeName = 'Examiner Report';
        } else if (lowerUrl.includes('rms') || lowerUrl.includes('msc') || lowerUrl.includes('mark-scheme') || lowerUrl.includes('mark_scheme')) {
          paperTypeName = 'Mark Scheme';
        }
        
        const { label, paperNumber, paperVariant, paperTier, paperComponent } = extractPaperMeta(fileName);
        
        let finalLabel = paperComponent || label;
        
        const { assetLabel, assetPriority } = getAssetMeta(fileName, paperTypeName);
        
        const entry: PastPaperEntry = {
          label: finalLabel,
          href: url,
          fileName,
          session: currentSession,
          sortDate: parseYearAndSessionToDate(currentSession).getTime(),
          paperNumber,
          paperVariant,
          paperTier,
          paperTypeName,
          assetLabel,
          assetPriority,
        };
        
        const sessionGroups = sessionMap.get(currentSession) ?? new Map<string, PastPaperGroup>();
        const existingGroup = sessionGroups.get(finalLabel) ?? {
          label: finalLabel,
          paperNumber,
          paperVariant,
          paperTier,
          questionPapers: [],
          markSchemes: [],
          examinerReports: [],
        };
        
        if (paperTypeName === 'Question Paper') {
          if (!existingGroup.questionPapers.some((paper) => paper.fileName === entry.fileName)) {
            existingGroup.questionPapers.push(entry);
          }
        } else if (paperTypeName === 'Examiner Report') {
          if (!existingGroup.examinerReports.some((paper) => paper.fileName === entry.fileName)) {
            existingGroup.examinerReports.push(entry);
          }
        } else if (!existingGroup.markSchemes.some((paper) => paper.fileName === entry.fileName)) {
          existingGroup.markSchemes.push(entry);
        }
        
        sessionGroups.set(finalLabel, existingGroup);
        sessionMap.set(currentSession, sessionGroups);
      }
    }
  }
  
  return Array.from(sessionMap.entries())
    .map(([label, groupsMap]) => ({
      label,
      sortDate: parseYearAndSessionToDate(label).getTime(),
      groups: Array.from(groupsMap.values())
        .map((group) => ({
          ...group,
          questionPapers: group.questionPapers.sort((a, b) => a.assetPriority - b.assetPriority || a.fileName.localeCompare(b.fileName)),
          examinerReports: group.examinerReports.sort((a, b) => a.assetPriority - b.assetPriority || a.fileName.localeCompare(b.fileName)),
          markSchemes: group.markSchemes.sort((a, b) => a.assetPriority - b.assetPriority || a.fileName.localeCompare(b.fileName)),
        }))
        .sort((a, b) => {
          if (a.paperNumber !== b.paperNumber) return a.paperNumber - b.paperNumber;
          return (variantRank[a.paperVariant] ?? 99) - (variantRank[b.paperVariant] ?? 99);
        }),
    }))
    .sort((a, b) => b.sortDate - a.sortDate);
}

const pastPaperContent = isBiology
  ? pastPaperContentModules['/src/newpastpapers/biologypapers.md']
  : isChemistry
    ? pastPaperContentModules['/src/newpastpapers/chemistrypapers.md']
    : isPhysics
      ? pastPaperContentModules['/src/newpastpapers/physicspapers.md']
      : isMaths
        ? pastPaperContentModules['/src/newpastpapers/mathspapers.md']
        : isIct
          ? pastPaperContentModules['/src/newpastpapers/ictpastpapers.md']
          : '';

const pastPaperSessions: PastPaperSession[] = pastPaperContent ? parsePastPaperContent(pastPaperContent, subjectId!) : [];

function parseYearAndSessionToDate(yearAndSession: string) {
  const yearMatch = yearAndSession.match(/(\d{4})/);
  const monthMatch = yearAndSession.match(/(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)/i);
  let date = new Date(0);

  if (yearMatch && monthMatch) {
    const year = Number.parseInt(yearMatch[1], 10);
    const monthIndex = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'].findIndex(
      (month) => month.toLowerCase() === monthMatch[1].toLowerCase(),
    );
    return new Date(year, monthIndex === -1 ? 0 : monthIndex, 1);
  }

  if (yearMatch) {
    return new Date(Number.parseInt(yearMatch[1], 10), 0, 1);
  }

  return date;
}

interface PastPaperEntry {
  label: string;
  href: string;
  fileName: string;
  session: string;
  sortDate: number;
  paperNumber: number;
  paperVariant: string;
  paperTier: 'foundation' | 'higher' | 'core' | 'unknown';
  paperTypeName: 'Question Paper' | 'Mark Scheme' | 'Examiner Report';
  assetLabel: string;
  assetPriority: number;
}

interface PastPaperGroup {
  label: string;
  paperNumber: number;
  paperVariant: string;
  paperTier: 'foundation' | 'higher' | 'core' | 'unknown';
  questionPapers: PastPaperEntry[];
  markSchemes: PastPaperEntry[];
  examinerReports: PastPaperEntry[];
}

interface PastPaperSession {
  label: string;
  sortDate: number;
  groups: PastPaperGroup[];
}

function getAssetMeta(fileName: string, paperTypeName: 'Question Paper' | 'Mark Scheme' | 'Examiner Report') {
  const normalized = fileName.replace(/\.pdf$/i, '').toLowerCase();

  if (paperTypeName === 'Examiner Report') {
    return { assetLabel: 'Examiner Report', assetPriority: 2 };
  }

  if (paperTypeName === 'Mark Scheme') {
    if (normalized.includes('detailed') || normalized.includes('solution')) {
      return { assetLabel: 'Detailed Solution', assetPriority: 3 };
    }
    if (normalized.includes('model answer')) {
      return { assetLabel: 'Model Answer', assetPriority: 2 };
    }
    return { assetLabel: 'Mark Scheme', assetPriority: 1 };
  }

  if (normalized.includes('unseen')) {
    return { assetLabel: 'Unseen Paper', assetPriority: 2 };
  }

  return { assetLabel: 'Question Paper', assetPriority: 1 };
}

function extractPaperMeta(fileName: string) {
  const rawFileName = fileName.replace(/\.pdf$/i, '');
  const newFormatMatch = rawFileName.match(/(?:^|[_\s-])(\d+)(FR|HR|BR|CR|PR|F|H|B|C|P)(?=[_\s-]|$)/i)
    || rawFileName.match(/_(\d+)([A-Za-z]+)_/);
  const legacyMatch = rawFileName.match(/paper[\s-]*(\d+)([a-z]*)/i);
  
  const ictPaperMatch = rawFileName.match(/(?:^|[_\s-])(0?1|0?2)(?:r?)(?=[_\s-]|$)/i);

  let paperNumber = 1;
  let paperVariant = 'Core';
  let paperTier: 'foundation' | 'higher' | 'core' | 'unknown' = 'core';
  let paperComponent: string | undefined = undefined;
  
  if (ictPaperMatch) {
    const component = ictPaperMatch[1].replace(/^0/, '');
    paperComponent = component === '1' ? 'Paper 1 (Theory)' : 'Paper 2 (Practical)';
    return { label: paperComponent, paperNumber: parseInt(component), paperVariant: 'Core', paperTier: 'core' as const, paperComponent };
  }

  if (newFormatMatch) {
    paperNumber = Number.parseInt(newFormatMatch[1], 10);
    const suffix = newFormatMatch[2].toUpperCase();
    if (suffix === 'FR') {
      paperVariant = 'Regional';
      paperTier = 'foundation';
    } else if (suffix === 'HR') {
      paperVariant = 'Regional';
      paperTier = 'higher';
    } else if (suffix.includes('BR') || suffix.includes('CR') || suffix.includes('PR')) {
      paperVariant = 'Regional';
      paperTier = 'core';
    } else if (suffix.includes('F')) {
      paperVariant = 'Foundation';
      paperTier = 'foundation';
    } else if (suffix.includes('H')) {
      paperVariant = 'Higher';
      paperTier = 'higher';
    }
  } else if (legacyMatch) {
    paperNumber = Number.parseInt(legacyMatch[1], 10);
    const suffix = legacyMatch[2].toLowerCase();
    if (suffix === 'fr') {
      paperVariant = 'Regional';
      paperTier = 'foundation';
    } else if (suffix === 'hr') {
      paperVariant = 'Regional';
      paperTier = 'higher';
    } else if (suffix.includes('r')) {
      paperVariant = 'Regional';
      paperTier = 'core';
    } else if (suffix === 'f') {
      paperVariant = 'Foundation';
      paperTier = 'foundation';
    } else if (suffix === 'h') {
      paperVariant = 'Higher';
      paperTier = 'higher';
    }
  }

  const lowerRawFileName = rawFileName.toLowerCase();
  if (paperTier === 'core' && /\bfoundation\b/.test(lowerRawFileName)) {
    paperVariant = 'Foundation';
    paperTier = 'foundation';
  } else if (paperTier === 'core' && /\bhigher\b/.test(lowerRawFileName)) {
    paperVariant = 'Higher';
    paperTier = 'higher';
  }

  let label = `Paper ${paperNumber}`;
  if (paperVariant === 'Regional' && paperTier === 'foundation') label += ' Foundation (Regional)';
  else if (paperVariant === 'Regional' && paperTier === 'higher') label += ' Higher (Regional)';
  else if (paperVariant === 'Regional') label += ' (Regional)';
  else if (paperVariant !== 'Core') label += ` ${paperVariant}`;

  return { label, paperNumber, paperVariant, paperTier };
}

const pastPaperSessionMap = new Map<string, Map<string, PastPaperGroup>>();

const totalPastPaperGroups = pastPaperSessions.reduce((sum, session) => sum + session.groups.length, 0);
const hasPastPapers = pastPaperSessions.length > 0;

const tabIcons: Record<string, string> = {
  notes: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2 0 0 1 0-5H20"/></svg>',
  synopsis: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  quiz: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>',
  practice: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>',
};
---

<Layout title={`${chapter.title} - ${subject.title}`}>
  <div class="page-wrapper patrick-hand">
    <Header />
    
    <main class="main-content">
      <section class="chapter-hero">
        <img src={bannerSrc} alt="" class="hero-bg-image" />
        <div class="hero-overlay"></div>
        <div class="container animate-fade-in">
          <nav class="breadcrumb">
            <a href="/" class="breadcrumb-link">Home</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            <a href="/subjects" class="breadcrumb-link">Subjects</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            <a href={`/subjects/${subjectId}`} class="breadcrumb-link">{subject.title}</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="breadcrumb-current">Chapter {chapter.number}</span>
          </nav>
          
          <div class="chapter-header">
            <div class="chapter-tag-wrap">
              <span class="chapter-tag" style={`background: ${subject.color}`}>Chapter {chapter.number}</span>
              {chapter.contentType && (
                <span class="chapter-tag content-type-tag" data-type={chapter.contentType}>{chapter.contentType === 'biology' ? 'Biology Only' : chapter.contentType === 'chemistry' ? 'Chemistry Only' : 'Physics Only'}</span>
              )}
            </div>
            <h1 class="hero-title wiggly-heading">{chapter.title}</h1>
            <p class="hero-subtitle">{chapter.synopsis}</p>
            <div class="chapter-meta">
              <span class="meta-item glass">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {chapter.estimatedTime}
              </span>
