---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SubjectCard from '../../components/SubjectCard.astro';
import Adsterra from '../../components/Adsterra.astro';
import { getSubjects } from '../../utils/subjects';

const subjects = getSubjects();
const subjectsList = Object.values(subjects);
---

<Layout title="All Subjects">
  <div class="page-wrapper">
    <Header />
    
    <main class="main-content">
      <section class="subjects-hero">
        <div class="container animate-fade-in">
          <nav class="breadcrumb">
            <a href="/" class="breadcrumb-link">Home</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="breadcrumb-current">Subjects</span>
          </nav>
          <h1 class="hero-title wiggly-heading">Master Your <span class="gradient-text">Subjects</span></h1>
          <p class="hero-subtitle">Browse our complete collection of IGCSE resources, curated for excellence.</p>
        </div>
      </section>

      <Adsterra position="content" />

      <section class="subjects-grid-section">
        <div class="container">
          <div class="subjects-grid">
            {subjectsList.length > 0 ? (
              subjectsList.map((subject: any) => (
                <SubjectCard 
                  title={subject.title}
                  description={subject.description}
                  href={`/subjects/${subject.id}`}
                  color={subject.color}
                  icon={subject.id}
                  chapterCount={subject.chapters.length}
                />
              ))
            ) : (
              <div class="empty-state">
                <p>No subjects available yet. Add subjects to the <code>/src/subjects</code> folder to get started.</p>
              </div>
            )}
          </div>
        </div>
      </section>
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
  }

  .subjects-hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, var(--app-bg-top) 0%, var(--app-bg-bottom) 100%);
    border-bottom: 2px solid var(--app-border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    font-size: 1rem;
    font-family: 'Patrick Hand', cursive;
  }

  .breadcrumb-link {
    color: var(--app-accent);
    text-decoration: none;
  }

  .breadcrumb-link:hover { text-decoration: underline; }
  .breadcrumb-current { color: var(--app-text-muted); }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 0 0 1rem 0;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-size: 1.4rem;
    color: var(--app-text-muted);
    max-width: 600px;
    font-family: 'Patrick Hand', cursive;
    line-height: 1.5;
  }

  .subjects-grid-section {
    padding: 6rem 0;
  }

  .subjects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--app-text-muted);
  }

  .empty-state code {
    background: var(--app-surface-muted);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }
</style>
