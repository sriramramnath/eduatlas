---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy - EduAtlas">
  <div class="page-wrapper">
    <Header />
    
    <main class="main-content">
      <section class="policy-hero">
        <div class="container animate-fade-in">
          <nav class="breadcrumb">
            <a href="/" class="breadcrumb-link">Home</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="breadcrumb-current">Privacy Policy</span>
          </nav>
          <h1 class="hero-title wiggly-heading">Privacy <span class="gradient-text">Policy</span></h1>
          <p class="hero-subtitle">How we collect, use, and protect your data.</p>
        </div>
      </section>

      <section class="policy-main-section">
        <div class="container">
          <div class="policy-card card glass">
            <h2 class="section-heading">Introduction</h2>
            <p class="section-text">
              Welcome to EduAtlas. Your privacy is critically important to us. This Privacy Policy outlines our practices regarding your use of our website. 
            </p>

            <h2 class="section-heading">Information We Collect</h2>
            <p class="section-text">
              <strong>We do not collect any personal information.</strong> EduAtlas is a free, openly accessible educational resource. We do not require you to create an account, sign in, or provide any personal details (such as your name, email address, or phone number) to use our platform.
            </p>

            <h2 class="section-heading">How We Use Your Information</h2>
            <p class="section-text">
              Because we do not collect any personal data, we do not store, process, or sell any of your information. Your usage of the site remains entirely anonymous as far as our systems are concerned.
            </p>
            
            <h2 class="section-heading">Third-Party Services</h2>
            <p class="section-text">
              While we do not collect personal data directly, we use third-party services like Google AdSense to serve advertisements that help keep EduAtlas free. Google uses cookies to serve ads based on your prior visits to our website or other websites on the internet. You can opt out of personalized advertising by visiting <a href="https://myadcenter.google.com/" target="_blank" rel="noopener noreferrer" class="text-accent">Google's Ads Settings</a>.
            </p>

            <h2 class="section-heading">Changes to This Policy</h2>
            <p class="section-text">
              We may update our Privacy Policy from time to time. We will notify you of any changes by posting the new Privacy Policy on this page and updating the "Last updated" date.
            </p>

            <h2 class="section-heading">Contact Us</h2>
            <p class="section-text">
              If you have any questions or concerns about this Privacy Policy, please contact us through the <a href="https://educationos.vercel.app" target="_blank" rel="noopener noreferrer" class="text-accent">EduOS platform</a>.
            </p>
            
            <div class="last-updated">
              Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </div>
          </div>
        </div>
      </section>
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
  }

  /* Policy Hero */
  .policy-hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, var(--app-bg-top) 0%, var(--app-bg-bottom) 100%);
    border-bottom: 2px solid var(--app-border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    font-size: 1rem;
    font-family: 'Patrick Hand', cursive;
  }

  .breadcrumb-link {
    color: var(--app-accent);
    text-decoration: none;
  }

  .breadcrumb-link:hover { text-decoration: underline; }
  .breadcrumb-current { color: var(--app-text-muted); }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 0 0 1.5rem 0;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-size: 1.4rem;
    color: var(--app-text-muted);
    max-width: 600px;
    font-family: 'Patrick Hand', cursive;
  }

  /* Policy Main Section */
  .policy-main-section { padding: 4rem 0 6rem; }

  .policy-card {
    padding: 3rem;
    border-radius: 2rem;
    border-width: 2px;
  }
  
  @media (min-width: 768px) {
    .policy-card {
      padding: 4rem;
    }
  }

  .section-heading { 
    font-size: 1.75rem; 
    margin: 2.5rem 0 1rem;
    color: var(--app-text);
  }
  
  .section-heading:first-child {
    margin-top: 0;
  }

  .section-text {
    font-size: 1.1rem;
    color: var(--app-text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-family: 'Inter', sans-serif;
  }

  .text-accent { 
    color: var(--app-accent-text); 
    font-weight: 600;
    text-decoration: none;
  }
  
  .text-accent:hover {
    text-decoration: underline;
  }
  
  .last-updated {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--app-border);
    color: var(--app-text-muted);
    font-style: italic;
  }
</style>
