---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found">
  <div class="page-wrapper patrick-hand">
    <Header />
    
    <main class="main-content">
      <section class="error-section">
        <div class="container error-container">
          <div class="error-visual animate-float">
            <div class="error-code gradient-text">404</div>
            <div class="error-icon-box glass">
              <img src="/Lightmodeicon.png" alt="EduAtlas Logo" class="error-logo" />
            </div>
          </div>
          
          <div class="error-content animate-fade-in">
            <h1 class="error-title wiggly-heading">Oops! You're Lost.</h1>
            <p class="error-message">
              The page you are looking for doesn't exist or has been moved. 
              Let's get you back on track to acing those exams!
            </p>
            <div class="error-actions">
              <a href="/" class="btn lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Go Home
              </a>
              <a href="/subjects" class="btn btn-secondary lg glass">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                Browse Subjects
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .main-content {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 0;
  }

  .error-section {
    width: 100%;
  }

  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3rem;
  }

  .error-visual {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .error-code {
    font-size: clamp(8rem, 20vw, 15rem);
    font-weight: 800;
    line-height: 1;
    opacity: 0.15;
    user-select: none;
  }

  .error-icon-box {
    position: absolute;
    width: 140px;
    height: 140px;
    border-radius: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--app-border);
    padding: 1.5rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    background: white;
    transform: rotate(-10deg);
  }

  .error-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .error-content {
    max-width: 600px;
  }

  .error-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: 1.5rem;
  }

  .error-message {
    font-size: 1.5rem;
    color: var(--app-text-muted);
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn.lg {
    padding: 1rem 2.5rem;
    font-size: 1.4rem;
  }

  .btn-icon {
    margin-right: 0.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .error-icon-box {
      background: #0f172a;
    }
  }
</style>
