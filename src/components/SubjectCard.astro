---
interface Props {
  title: string;
  description: string;
  href: string;
  color: string;
  icon: string;
  chapterCount: number;
}

const { title, description, href, color, chapterCount } = Astro.props;

const bannerMap: Record<string, string> = {
  'Biology': '/banners/biology.png',
  'Chemistry': '/banners/chemistry.png',
  'Physics': '/banners/physics.png',
  'Math': '/banners/math.png',
  'Mathematics': '/banners/math.png',
  'ICT': '/banners/compsci.png',
};

const iconMap: Record<string, string> = {
  'Biology': '/icons/lightmode/Biology.svg',
  'Chemistry': '/icons/lightmode/Chemistry.svg',
  'Physics': '/icons/lightmode/Physics.svg',
  'Math': '/icons/lightmode/Maths.svg',
  'Mathematics': '/icons/lightmode/Maths.svg',
  'ICT': '/icons/lightmode/ICT.svg',
};

const darkIconMap: Record<string, string> = {
  'Biology': '/icons/darkmode/Biology.svg',
  'Chemistry': '/icons/darkmode/Chemistry.svg',
  'Physics': '/icons/darkmode/Physics.svg',
  'Math': '/icons/darkmode/Maths.svg',
  'Mathematics': '/icons/darkmode/Maths.svg',
  'ICT': '/icons/darkmode/ICT.svg',
};

const iconSrc = iconMap[title] || '';
const darkIconSrc = darkIconMap[title] || '';
const bannerSrc = bannerMap[title] || '';
---

<a href={href} class="subject-card card glass patrick-hand" style={`--accent: ${color}`}>
  <div class="card-banner">
    <img src={bannerSrc} alt={title} class="banner-image-bg" />
    <div class="banner-overlay"></div>
    <div class="subject-icon-box" style={`border-color: ${color}`}>
       <img src={iconSrc} data-light-src={iconSrc} data-dark-src={darkIconSrc} alt="" class="subject-icon-img" />
    </div>
  </div>
  
  <div class="card-body">
    <div class="card-meta">
      <span class="chapter-badge">{chapterCount} Chapters</span>
    </div>
    <h3 class="subject-title">{title}</h3>
    <p class="subject-description">{description}</p>
    
    <div class="card-footer">
      <span class="learn-more">
        Let's Learn!
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="arrow"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </span>
    </div>
  </div>
  <script>
    function updateIconTheme() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      document.querySelectorAll('.subject-icon-img[data-dark-src]').forEach((img: HTMLImageElement) => {
        img.src = isDark ? img.dataset.darkSrc : img.dataset.lightSrc;
      });
    }
    updateIconTheme();
    const observer = new MutationObserver(updateIconTheme);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  </script>
</a>

<style>
  .subject-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    height: 100%;
    border-radius: 2rem;
    overflow: hidden;
    color: var(--app-text);
  }

  .patrick-hand {
    font-family: 'Patrick Hand', cursive !important;
  }

  .card-banner {
    height: 160px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .banner-image-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.8) brightness(0.9);
    transition: transform 0.5s ease;
  }

  :global([data-theme="dark"]) .banner-image-bg {
    filter: saturate(0.8) brightness(1.2);
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.4) 100%);
  }

  .subject-icon-box {
    width: 64px;
    height: 64px;
    border-radius: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F1F5F9;
    border: 3px solid;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    z-index: 1;
    transform: rotate(-5deg);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    overflow: hidden;
  }

  .subject-icon-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global([data-theme="dark"]) .subject-icon-box {
    background: #070B1B;
  }

  .card-body {
    padding: 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-meta {
    margin-bottom: 0.75rem;
  }

  .chapter-badge {
    padding: 0.25rem 0.85rem;
    background: var(--app-accent-weak);
    color: var(--app-accent-text);
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
  }

  .subject-title {
    font-size: 2rem;
    margin: 0 0 0.75rem 0;
    font-weight: 700;
  }

  .subject-description {
    color: var(--app-text-muted);
    font-size: 1.25rem;
    line-height: 1.4;
    margin: 0 0 2rem 0;
    flex: 1;
  }

  .card-footer {
    padding-top: 1rem;
    border-top: 2px dashed var(--app-border);
  }

  .learn-more {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--accent);
  }

  .arrow {
    transition: transform 0.3s ease;
  }

  .subject-card:hover {
    border-color: var(--accent);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.12);
  }

  .subject-card:hover .banner-image-bg {
    transform: scale(1.1);
  }

  .subject-card:hover .subject-icon-box {
    transform: rotate(5deg) scale(1.1);
  }

  .subject-card:hover .arrow {
    transform: translateX(6px) rotate(-15deg);
  }
</style>
